---
import Base from '../layouts/Base.astro';
import RetroWindow from '../components/RetroWindow.astro';

// Pixel-art scene, Pokémon Emerald / Black-&-White inspired.
// ViewBox is a small 480x270 and everything is drawn on integer pixel
// coordinates; shape-rendering="crispEdges" + CSS image-rendering:pixelated
// preserves the chunky look at any viewport size.
---

<Base>
	<div class="scene" id="scene" role="main" aria-label="figtre.es home scene">
		<svg
			class="landscape"
			viewBox="0 0 480 270"
			preserveAspectRatio="xMinYMid slice"
			shape-rendering="crispEdges"
			role="img"
			aria-labelledby="sceneDesc"
			data-desktop-viewbox="0 0 480 270"
			data-mobile-viewbox="0 0 200 270"
		>
			<desc id="sceneDesc">
				A pixel-art fig tree on the left of a muted landscape, with a person sitting beneath it, looking out over dithered sage hills under a dithered blue sky. Figs and fig leaves on the tree are interactive.
			</desc>

			<defs>
				<!-- Dithered sky: classic GBA/DS 2x2 checkerboard blending two
				     blues for a low-bit look. Two bands — upper and horizon —
				     give a sense of atmospheric depth. -->
				<pattern id="skyTop" width="2" height="2" patternUnits="userSpaceOnUse">
					<rect width="2" height="2" fill="#6a98b8" />
					<rect x="0" y="0" width="1" height="1" fill="#82adc7" />
					<rect x="1" y="1" width="1" height="1" fill="#82adc7" />
				</pattern>
				<pattern id="skyHi" width="2" height="2" patternUnits="userSpaceOnUse">
					<rect width="2" height="2" fill="#7ea6c2" />
					<rect x="0" y="0" width="1" height="1" fill="#95bcd2" />
					<rect x="1" y="1" width="1" height="1" fill="#95bcd2" />
				</pattern>
				<pattern id="skyMid" width="2" height="2" patternUnits="userSpaceOnUse">
					<rect width="2" height="2" fill="#9abcce" />
					<rect x="0" y="0" width="1" height="1" fill="#b1ccda" />
					<rect x="1" y="1" width="1" height="1" fill="#b1ccda" />
				</pattern>
				<pattern id="skyLo" width="2" height="2" patternUnits="userSpaceOnUse">
					<rect width="2" height="2" fill="#b5ccd8" />
					<rect x="0" y="0" width="1" height="1" fill="#cedae2" />
					<rect x="1" y="1" width="1" height="1" fill="#cedae2" />
				</pattern>
				<pattern id="skyHaze" width="2" height="2" patternUnits="userSpaceOnUse">
					<rect width="2" height="2" fill="#d8dfe0" />
					<rect x="0" y="0" width="1" height="1" fill="#e7ebe8" />
					<rect x="1" y="1" width="1" height="1" fill="#e7ebe8" />
				</pattern>

				<!-- Dithered grass field -->
				<pattern id="grass" width="2" height="2" patternUnits="userSpaceOnUse">
					<rect width="2" height="2" fill="#6a8a4c" />
					<rect x="0" y="0" width="1" height="1" fill="#7d9e5c" />
					<rect x="1" y="1" width="1" height="1" fill="#7d9e5c" />
				</pattern>

				<!-- Distant mountain silhouette (desaturated cool purple, aerial perspective) -->
				<pattern id="mountFar" width="2" height="2" patternUnits="userSpaceOnUse">
					<rect width="2" height="2" fill="#7b839a" />
					<rect x="0" y="0" width="1" height="1" fill="#8c94a8" />
					<rect x="1" y="1" width="1" height="1" fill="#8c94a8" />
				</pattern>

				<!-- Three hill-distance shades: far (lightest) → mid → near (deepest) -->
				<pattern id="hillFar" width="2" height="2" patternUnits="userSpaceOnUse">
					<rect width="2" height="2" fill="#8ba17a" />
					<rect x="0" y="0" width="1" height="1" fill="#a0b68d" />
					<rect x="1" y="1" width="1" height="1" fill="#a0b68d" />
				</pattern>
				<pattern id="hillMid" width="2" height="2" patternUnits="userSpaceOnUse">
					<rect width="2" height="2" fill="#789066" />
					<rect x="0" y="0" width="1" height="1" fill="#8aa478" />
					<rect x="1" y="1" width="1" height="1" fill="#8aa478" />
				</pattern>
				<pattern id="hillNear" width="2" height="2" patternUnits="userSpaceOnUse">
					<rect width="2" height="2" fill="#5e7e50" />
					<rect x="0" y="0" width="1" height="1" fill="#6e8c5e" />
					<rect x="1" y="1" width="1" height="1" fill="#6e8c5e" />
				</pattern>

				<!-- Ripe fig pixel sprite (8x10). Integer coords only. -->
				<symbol id="ripeFig" viewBox="0 0 8 10" overflow="visible">
					<!-- stem -->
					<rect x="3" y="0" width="2" height="1" fill="#3d5220" />
					<rect x="2" y="1" width="4" height="1" fill="#5d7d35" />
					<!-- shoulders: green-yellow blotch blending into mulberry -->
					<rect x="1" y="2" width="2" height="1" fill="#8aa04c" />
					<rect x="3" y="2" width="4" height="1" fill="#6d3f52" />
					<!-- body rows getting darker -->
					<rect x="0" y="3" width="8" height="1" fill="#6d3f52" />
					<rect x="0" y="4" width="8" height="1" fill="#5a3546" />
					<rect x="0" y="5" width="8" height="1" fill="#4a2735" />
					<rect x="0" y="6" width="8" height="1" fill="#3b1c28" />
					<!-- round bottom -->
					<rect x="1" y="7" width="6" height="1" fill="#3b1c28" />
					<rect x="2" y="8" width="4" height="1" fill="#2a1020" />
					<rect x="3" y="9" width="2" height="1" fill="#1a0814" />
					<!-- highlight pixels (upper-left, catches the light) -->
					<rect x="1" y="3" width="1" height="1" fill="#8a6a7c" />
					<rect x="1" y="4" width="1" height="1" fill="#775a6c" />
				</symbol>

				<!-- Fig leaf pixel sprite (12x12): 3-lobed palmate. -->
				<symbol id="figLeaf" viewBox="0 0 12 12" overflow="visible">
					<!-- center lobe (tallest) -->
					<rect x="5" y="0" width="2" height="1" fill="#4a6a2e" />
					<rect x="4" y="1" width="4" height="2" fill="#557a35" />
					<!-- left lobe -->
					<rect x="1" y="1" width="2" height="1" fill="#4a6a2e" />
					<rect x="0" y="2" width="3" height="2" fill="#557a35" />
					<!-- right lobe -->
					<rect x="9" y="1" width="2" height="1" fill="#4a6a2e" />
					<rect x="9" y="2" width="3" height="2" fill="#557a35" />
					<!-- upper-body merge -->
					<rect x="2" y="3" width="8" height="1" fill="#557a35" />
					<rect x="1" y="4" width="10" height="2" fill="#557a35" />
					<!-- lower body -->
					<rect x="2" y="6" width="8" height="1" fill="#4a6a2e" />
					<rect x="3" y="7" width="6" height="1" fill="#4a6a2e" />
					<rect x="4" y="8" width="4" height="1" fill="#3d5520" />
					<!-- stem -->
					<rect x="5" y="9" width="2" height="3" fill="#3d5220" />
					<!-- vein hints -->
					<rect x="5" y="3" width="1" height="5" fill="#3d5520" />
				</symbol>
			</defs>

			<!-- ========== SKY (layered bands with disrupted edges) ========== -->
			<rect width="480" height="24" fill="url(#skyTop)" />
			<rect y="24" width="480" height="40" fill="url(#skyHi)" />
			<rect y="64" width="480" height="28" fill="url(#skyMid)" />
			<rect y="92" width="480" height="18" fill="url(#skyLo)" />

			<!-- skyTop fingers dipping into skyHi (breaks horizontal edge) -->
			<g>
				<rect x="20" y="24" width="3" height="4" fill="url(#skyTop)" />
				<rect x="74" y="24" width="4" height="3" fill="url(#skyTop)" />
				<rect x="120" y="24" width="3" height="5" fill="url(#skyTop)" />
				<rect x="180" y="24" width="4" height="4" fill="url(#skyTop)" />
				<rect x="244" y="24" width="3" height="4" fill="url(#skyTop)" />
				<rect x="310" y="24" width="4" height="3" fill="url(#skyTop)" />
				<rect x="360" y="24" width="3" height="5" fill="url(#skyTop)" />
				<rect x="424" y="24" width="3" height="4" fill="url(#skyTop)" />
			</g>
			<!-- skyHi fingers reaching up into skyTop -->
			<g>
				<rect x="48" y="20" width="3" height="4" fill="url(#skyHi)" />
				<rect x="98" y="21" width="4" height="3" fill="url(#skyHi)" />
				<rect x="152" y="22" width="3" height="2" fill="url(#skyHi)" />
				<rect x="212" y="20" width="4" height="4" fill="url(#skyHi)" />
				<rect x="278" y="22" width="3" height="2" fill="url(#skyHi)" />
				<rect x="334" y="21" width="3" height="3" fill="url(#skyHi)" />
				<rect x="392" y="20" width="4" height="4" fill="url(#skyHi)" />
				<rect x="448" y="22" width="3" height="2" fill="url(#skyHi)" />
			</g>

			<!-- skyHi fingers dipping into skyMid -->
			<g>
				<rect x="34" y="64" width="4" height="4" fill="url(#skyHi)" />
				<rect x="88" y="64" width="3" height="3" fill="url(#skyHi)" />
				<rect x="144" y="64" width="4" height="5" fill="url(#skyHi)" />
				<rect x="196" y="64" width="3" height="3" fill="url(#skyHi)" />
				<rect x="250" y="64" width="4" height="4" fill="url(#skyHi)" />
				<rect x="316" y="64" width="3" height="3" fill="url(#skyHi)" />
				<rect x="372" y="64" width="4" height="5" fill="url(#skyHi)" />
				<rect x="436" y="64" width="3" height="3" fill="url(#skyHi)" />
			</g>
			<!-- skyMid fingers reaching up into skyHi -->
			<g>
				<rect x="66" y="60" width="3" height="4" fill="url(#skyMid)" />
				<rect x="116" y="61" width="4" height="3" fill="url(#skyMid)" />
				<rect x="168" y="62" width="3" height="2" fill="url(#skyMid)" />
				<rect x="228" y="60" width="4" height="4" fill="url(#skyMid)" />
				<rect x="290" y="62" width="3" height="2" fill="url(#skyMid)" />
				<rect x="348" y="61" width="3" height="3" fill="url(#skyMid)" />
				<rect x="408" y="60" width="4" height="4" fill="url(#skyMid)" />
				<rect x="460" y="62" width="3" height="2" fill="url(#skyMid)" />
			</g>

			<!-- skyMid/skyLo transition -->
			<g>
				<rect x="26" y="92" width="3" height="3" fill="url(#skyMid)" />
				<rect x="80" y="92" width="4" height="4" fill="url(#skyMid)" />
				<rect x="132" y="92" width="3" height="3" fill="url(#skyMid)" />
				<rect x="190" y="92" width="4" height="4" fill="url(#skyMid)" />
				<rect x="256" y="92" width="3" height="3" fill="url(#skyMid)" />
				<rect x="318" y="92" width="4" height="4" fill="url(#skyMid)" />
				<rect x="380" y="92" width="3" height="3" fill="url(#skyMid)" />
				<rect x="446" y="92" width="4" height="4" fill="url(#skyMid)" />
			</g>
			<g>
				<rect x="54" y="88" width="3" height="4" fill="url(#skyLo)" />
				<rect x="110" y="90" width="4" height="2" fill="url(#skyLo)" />
				<rect x="164" y="89" width="3" height="3" fill="url(#skyLo)" />
				<rect x="222" y="88" width="4" height="4" fill="url(#skyLo)" />
				<rect x="286" y="90" width="3" height="2" fill="url(#skyLo)" />
				<rect x="352" y="89" width="3" height="3" fill="url(#skyLo)" />
				<rect x="412" y="88" width="4" height="4" fill="url(#skyLo)" />
				<rect x="468" y="90" width="4" height="2" fill="url(#skyLo)" />
			</g>

			<!-- ========== DISTANT MOUNTAINS ========== -->
			<g>
				<!-- mountain 1: left -->
				<rect x="100" y="112" width="4" height="2" fill="url(#mountFar)" />
				<rect x="96" y="114" width="14" height="2" fill="url(#mountFar)" />
				<rect x="92" y="116" width="22" height="2" fill="url(#mountFar)" />
				<rect x="88" y="118" width="30" height="2" fill="url(#mountFar)" />
				<rect x="84" y="120" width="38" height="2" fill="url(#mountFar)" />
				<!-- mountain 2: right of center, tallest -->
				<rect x="220" y="106" width="4" height="2" fill="url(#mountFar)" />
				<rect x="216" y="108" width="12" height="2" fill="url(#mountFar)" />
				<rect x="212" y="110" width="20" height="2" fill="url(#mountFar)" />
				<rect x="208" y="112" width="28" height="2" fill="url(#mountFar)" />
				<rect x="204" y="114" width="36" height="2" fill="url(#mountFar)" />
				<rect x="200" y="116" width="44" height="2" fill="url(#mountFar)" />
				<rect x="196" y="118" width="52" height="2" fill="url(#mountFar)" />
				<rect x="192" y="120" width="60" height="2" fill="url(#mountFar)" />
				<!-- mountain 3: right -->
				<rect x="330" y="112" width="4" height="2" fill="url(#mountFar)" />
				<rect x="326" y="114" width="14" height="2" fill="url(#mountFar)" />
				<rect x="322" y="116" width="22" height="2" fill="url(#mountFar)" />
				<rect x="318" y="118" width="30" height="2" fill="url(#mountFar)" />
				<rect x="314" y="120" width="38" height="2" fill="url(#mountFar)" />
				<!-- mountain 4: far right -->
				<rect x="420" y="114" width="4" height="2" fill="url(#mountFar)" />
				<rect x="416" y="116" width="14" height="2" fill="url(#mountFar)" />
				<rect x="412" y="118" width="22" height="2" fill="url(#mountFar)" />
				<rect x="408" y="120" width="30" height="2" fill="url(#mountFar)" />
			</g>

			<!-- ========== CLOUDS (bigger, multi-lobe, BW2-style) ========== -->
			<!-- Big cumulus, upper-center. 3 stacked lobes across ~80px -->
			<g class="drift drift-a">
				<!-- top highlights (two small caps) -->
				<rect x="258" y="12" width="10" height="1" fill="#ffffff" />
				<rect x="278" y="8" width="14" height="1" fill="#ffffff" />
				<rect x="298" y="14" width="12" height="1" fill="#ffffff" />
				<!-- upper body lobes -->
				<rect x="256" y="13" width="14" height="2" fill="#ffffff" />
				<rect x="274" y="9" width="22" height="3" fill="#ffffff" />
				<rect x="296" y="15" width="18" height="2" fill="#ffffff" />
				<rect x="252" y="15" width="20" height="3" fill="#ffffff" />
				<rect x="270" y="12" width="30" height="3" fill="#ffffff" />
				<rect x="294" y="17" width="22" height="3" fill="#ffffff" />
				<!-- main body (widest) -->
				<rect x="248" y="18" width="70" height="4" fill="#ffffff" />
				<rect x="244" y="22" width="78" height="4" fill="#ffffff" />
				<rect x="250" y="26" width="64" height="2" fill="#ffffff" />
				<!-- shadow layers -->
				<rect x="250" y="28" width="62" height="1" fill="#d3dde5" />
				<rect x="254" y="29" width="54" height="1" fill="#b8c9d4" />
				<rect x="262" y="30" width="38" height="1" fill="#9faebd" />
			</g>

			<!-- Medium-large cloud, upper right -->
			<g class="drift drift-b">
				<rect x="388" y="36" width="14" height="1" fill="#ffffff" />
				<rect x="406" y="34" width="10" height="1" fill="#ffffff" />
				<rect x="384" y="37" width="20" height="2" fill="#ffffff" />
				<rect x="402" y="35" width="18" height="3" fill="#ffffff" />
				<rect x="380" y="39" width="50" height="4" fill="#ffffff" />
				<rect x="376" y="43" width="58" height="3" fill="#ffffff" />
				<rect x="380" y="46" width="50" height="2" fill="#ffffff" />
				<!-- shadow -->
				<rect x="380" y="48" width="48" height="1" fill="#c3d2dc" />
				<rect x="386" y="49" width="36" height="1" fill="#a9bcc8" />
			</g>

			<!-- Smaller fluffy cloud, far-right lower -->
			<g class="drift drift-c">
				<rect x="438" y="66" width="12" height="1" fill="#ffffff" />
				<rect x="434" y="67" width="20" height="2" fill="#ffffff" />
				<rect x="430" y="69" width="30" height="3" fill="#ffffff" />
				<rect x="436" y="72" width="20" height="1" fill="#ffffff" />
				<rect x="436" y="73" width="20" height="1" fill="#c3d2dc" />
			</g>

			<!-- Wispy horizon streak -->
			<g class="drift drift-a">
				<rect x="132" y="84" width="36" height="1" fill="#e6eef2" />
				<rect x="128" y="85" width="44" height="1" fill="#f4f7f8" />
				<rect x="132" y="86" width="36" height="1" fill="#cedae2" />
			</g>

			<!-- Small background cloud, upper-left -->
			<g class="drift drift-b">
				<rect x="52" y="30" width="10" height="1" fill="#ffffff" />
				<rect x="48" y="31" width="18" height="2" fill="#ffffff" />
				<rect x="44" y="33" width="26" height="3" fill="#ffffff" />
				<rect x="48" y="36" width="18" height="1" fill="#ffffff" />
				<rect x="52" y="37" width="10" height="1" fill="#c3d2dc" />
			</g>

			<!-- ========== FOREGROUND HILL (one rolling form — Bliss-style) ==========
			     The whole ground is one continuous grass silhouette. Its TOP
			     edge is the horizon line, drawn as pixel columns of varying
			     height so the ridge rolls up and down gently. Below the ridge
			     the grass pattern extends to the bottom of the scene. No
			     stacked hill bands, no horizon haze strip. -->
			<g>
				<!-- Each rect is a vertical column extending from its top-y
				     down to y=270 (bottom of viewBox). Top-y varies to form
				     the rolling ridge profile. -->
				<rect x="0"   y="134" width="14"  height="136" fill="url(#grass)" />
				<rect x="14"  y="130" width="12"  height="140" fill="url(#grass)" />
				<rect x="26"  y="126" width="14"  height="144" fill="url(#grass)" />
				<rect x="40"  y="122" width="16"  height="148" fill="url(#grass)" />
				<rect x="56"  y="118" width="16"  height="152" fill="url(#grass)" />
				<rect x="72"  y="116" width="14"  height="154" fill="url(#grass)" />
				<rect x="86"  y="116" width="20"  height="154" fill="url(#grass)" />
				<rect x="106" y="118" width="18"  height="152" fill="url(#grass)" />
				<rect x="124" y="121" width="18"  height="149" fill="url(#grass)" />
				<rect x="142" y="125" width="22"  height="145" fill="url(#grass)" />
				<rect x="164" y="127" width="30"  height="143" fill="url(#grass)" />
				<rect x="194" y="125" width="18"  height="145" fill="url(#grass)" />
				<rect x="212" y="122" width="18"  height="148" fill="url(#grass)" />
				<rect x="230" y="119" width="20"  height="151" fill="url(#grass)" />
				<rect x="250" y="115" width="24"  height="155" fill="url(#grass)" />
				<rect x="274" y="113" width="20"  height="157" fill="url(#grass)" />
				<rect x="294" y="115" width="20"  height="155" fill="url(#grass)" />
				<rect x="314" y="118" width="20"  height="152" fill="url(#grass)" />
				<rect x="334" y="122" width="20"  height="148" fill="url(#grass)" />
				<rect x="354" y="125" width="22"  height="145" fill="url(#grass)" />
				<rect x="376" y="129" width="22"  height="141" fill="url(#grass)" />
				<rect x="398" y="132" width="26"  height="138" fill="url(#grass)" />
				<rect x="424" y="134" width="26"  height="136" fill="url(#grass)" />
				<rect x="450" y="135" width="30"  height="135" fill="url(#grass)" />

				<!-- Small pixel jitter above each column top so the ridge
				     doesn't read as a perfectly stepped staircase -->
				<rect x="6"   y="133" width="4" height="1" fill="url(#grass)" />
				<rect x="34"  y="125" width="4" height="1" fill="url(#grass)" />
				<rect x="66"  y="117" width="4" height="1" fill="url(#grass)" />
				<rect x="96"  y="115" width="4" height="1" fill="url(#grass)" />
				<rect x="154" y="126" width="4" height="1" fill="url(#grass)" />
				<rect x="180" y="126" width="6" height="1" fill="url(#grass)" />
				<rect x="222" y="121" width="4" height="1" fill="url(#grass)" />
				<rect x="264" y="114" width="4" height="1" fill="url(#grass)" />
				<rect x="284" y="112" width="4" height="1" fill="url(#grass)" />
				<rect x="326" y="121" width="4" height="1" fill="url(#grass)" />
				<rect x="366" y="128" width="4" height="1" fill="url(#grass)" />
				<rect x="410" y="131" width="4" height="1" fill="url(#grass)" />
				<rect x="440" y="133" width="4" height="1" fill="url(#grass)" />
				<rect x="472" y="134" width="4" height="1" fill="url(#grass)" />
			</g>

			<!-- Thin sun-lit highlight row at the very top of the ridge
			     (catches the light, subtle BW2-ish detail) -->
			<g fill="#9ab870">
				<rect x="0"   y="134" width="14" height="1" />
				<rect x="14"  y="130" width="12" height="1" />
				<rect x="26"  y="126" width="14" height="1" />
				<rect x="40"  y="122" width="16" height="1" />
				<rect x="56"  y="118" width="16" height="1" />
				<rect x="72"  y="116" width="14" height="1" />
				<rect x="86"  y="116" width="20" height="1" />
				<rect x="106" y="118" width="18" height="1" />
				<rect x="124" y="121" width="18" height="1" />
				<rect x="142" y="125" width="22" height="1" />
				<rect x="164" y="127" width="30" height="1" />
				<rect x="194" y="125" width="18" height="1" />
				<rect x="212" y="122" width="18" height="1" />
				<rect x="230" y="119" width="20" height="1" />
				<rect x="250" y="115" width="24" height="1" />
				<rect x="274" y="113" width="20" height="1" />
				<rect x="294" y="115" width="20" height="1" />
