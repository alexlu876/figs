<style>
	.scene {
		position: relative;
		width: 100vw;
		height: 100vh;
		overflow: hidden;
		background: #7ea6c2;
	}
	@media (max-width: 640px) {
		.scene {
			background: linear-gradient(to bottom, #7ea6c2 0%, #b5ccd8 45%, #8aa478 55%, #6a8a4c 100%);
		}
	}
	.landscape {
		width: 100%;
		height: 100%;
		display: block;
		/* Render the scaled-up SVG with nearest-neighbor so the pixel
		   aesthetic holds at any viewport size. */
		image-rendering: pixelated;
		image-rendering: -moz-crisp-edges;
		image-rendering: crisp-edges;
	}
	.hotspot {
		cursor: pointer;
		transition: filter 140ms ease, transform 140ms ease;
		transform-box: fill-box;
		transform-origin: center;
	}
	.hotspot:hover {
		filter: brightness(1.2) drop-shadow(1px 1px 0 #f4e3a8);
		transform: scale(1.12);
	}
	.hotspot:focus { outline: none; }
	.hotspot:focus-visible {
		filter: brightness(1.22);
		outline: 2px dashed #f4e3a8;
		outline-offset: 2px;
	}
	/* Small warm pixel shadow on interactive leaves */
	.hotspot-leaf use { filter: drop-shadow(1px 1px 0 #3d5220); }

	@keyframes breathe {
		0%   { transform: scale(1); }
		50%  { transform: scale(1.12); }
		100% { transform: scale(1); }
	}
	.hotspot-pulse .pulse-target {
		transform-box: fill-box;
		transform-origin: center;
		animation: breathe 3.2s steps(4, end) infinite;
	}
	.hotspot-pulse:hover .pulse-target { animation-play-state: paused; }

	@keyframes pssst {
		0%   { transform: translate(0, 0); }
		25%  { transform: translate(0, -1px); }
		50%  { transform: translate(0, 1px); }
		100% { transform: translate(0, 0); }
	}
	.hotspot.pssst {
		transform-box: fill-box;
		transform-origin: center;
		animation: pssst 1.2s steps(4, end) 1;
	}
	@media (prefers-reduced-motion: reduce) {
		.hotspot-pulse .pulse-target { animation: none; }
		.hotspot.pssst { animation: none; }
		.drift-a, .drift-b, .drift-c { animation: none; }
	}

	/* Very slow cloud drift — small pixel-step offsets so it still feels
	   tile-based rather than continuous. */
	@keyframes driftA { from { transform: translateX(0); } to { transform: translateX(10px); } }
	@keyframes driftB { from { transform: translateX(0); } to { transform: translateX(-8px); } }
	@keyframes driftC { from { transform: translateX(0); } to { transform: translateX(6px); } }
	.drift-a { animation: driftA 80s steps(10, end) infinite alternate; }
	.drift-b { animation: driftB 100s steps(8, end) infinite alternate; }
	.drift-c { animation: driftC 120s steps(6, end) infinite alternate; }
</style>

<script>
	const scene = document.getElementById('scene');
	if (scene) {
		let topZ = 10;

		// Mobile: zoom into the left portion of the scene so the tree fills
		// the narrow viewport instead of the sky dominating.
		const svg = scene.querySelector<SVGSVGElement>('svg.landscape');
		const mobileQuery = window.matchMedia('(max-width: 640px)');
		const applyMobileScene = (isMobile: boolean) => {
			if (!svg) return;
			const desktopVB = svg.dataset.desktopViewbox || '0 0 480 270';
			const mobileVB = svg.dataset.mobileViewbox || '0 0 200 270';
			svg.setAttribute('viewBox', isMobile ? mobileVB : desktopVB);
			svg.setAttribute(
				'preserveAspectRatio',
				isMobile ? 'xMidYMid meet' : 'xMinYMid slice',
			);
		};
		applyMobileScene(mobileQuery.matches);
		if ('addEventListener' in mobileQuery) {
			mobileQuery.addEventListener('change', (e) => applyMobileScene(e.matches));
		}

		const bringToFront = (el: HTMLElement) => {
			topZ += 1;
			el.style.zIndex = String(topZ);
		};

		const openWindow = (id: string) => {
			const win = document.getElementById(`window-${id}`) as HTMLElement | null;
			if (!win) return;
			win.hidden = false;
			bringToFront(win);
		};

		const hotspots = scene.querySelectorAll<SVGElement>('.hotspot');
		hotspots.forEach((el) => {
			const id = (el as SVGElement & { dataset: DOMStringMap }).dataset.window;
			if (!id) return;
			el.addEventListener('click', () => openWindow(id));
			el.addEventListener('keydown', (e) => {
				const ke = e as KeyboardEvent;
				if (ke.key === 'Enter' || ke.key === ' ') {
					ke.preventDefault();
					openWindow(id);
				}
			});
		});

		// One-shot pssst bob ~1.8s after load
		const rm = window.matchMedia('(prefers-reduced-motion: reduce)');
		if (!rm.matches) {
			window.setTimeout(() => {
				hotspots.forEach((el, i) => {
					window.setTimeout(() => {
						el.classList.add('pssst');
						el.addEventListener(
							'animationend',
							() => el.classList.remove('pssst'),
							{ once: true }
						);
					}, i * 120);
				});
			}, 1800);
		}

		const mobileMq = window.matchMedia('(max-width: 640px)');
		scene.querySelectorAll<HTMLElement>('.window').forEach((win) => {
			win.addEventListener('mousedown', () => bringToFront(win));

			win.querySelectorAll<HTMLButtonElement>('[data-close]').forEach((btn) => {
				btn.addEventListener('click', () => {
					win.hidden = true;
				});
			});

			const handle = win.querySelector<HTMLElement>('[data-drag-handle]');
			if (!handle) return;

			let dragging = false;
			let offsetX = 0;
			let offsetY = 0;

			handle.addEventListener('mousedown', (e) => {
				if (mobileMq.matches) return;
				if ((e.target as HTMLElement).closest('[data-close]')) return;
				dragging = true;
				const rect = win.getBoundingClientRect();
				offsetX = e.clientX - rect.left;
				offsetY = e.clientY - rect.top;
				e.preventDefault();
			});

			document.addEventListener('mousemove', (e) => {
				if (!dragging) return;
				win.style.left = `${e.clientX - offsetX}px`;
				win.style.top = `${e.clientY - offsetY}px`;
			});

			document.addEventListener('mouseup', () => {
				dragging = false;
			});
		});
	}
</script>
