			</g>

			<g class="figs">
				{/* The 'about' fig carries the breathe pulse + one-shot bob so
				    first-time visitors see that something on the tree is alive
				    and clickable. Only one hotspot gets the continuous pulse —
				    five would be noisy. Animations are gated via
				    prefers-reduced-motion below. */}
				<g class="hotspot hotspot-pulse" data-window="about" tabindex="0" role="button" aria-label="Open about">
					<title>about</title>
					<g transform="translate(300 200) scale(1.3)" filter="url(#figShadow)">
