				<!-- subtle leg separation line between bent + extended legs -->
				<path d="M 4 28 Q 16 24, 30 18" stroke="#1a130c" stroke-width="1.5" fill="none" opacity="0.5" />
			</g>

			<!-- =========================================================
			     CLICKABLE HOTSPOTS — figs + leaves on the tree.
			     The leaves are positioned OUTSIDE the dense canopy mass so
			     they clearly read as "a fig leaf protruding" rather than
			     being lost in the foliage. A warm cream rim-stroke gives a
