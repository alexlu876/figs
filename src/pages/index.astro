---
import Base from '../layouts/Base.astro';
import RetroWindow from '../components/RetroWindow.astro';

// Pixel-art scene, Pokémon Emerald / Black-&-White inspired.
// ViewBox is a small 480x270 and everything is drawn on integer pixel
// coordinates; shape-rendering="crispEdges" + CSS image-rendering:pixelated
// preserves the chunky look at any viewport size.
---

<Base>
	<div class="scene" id="scene" role="main" aria-label="figtre.es home scene">
		<svg
			class="landscape"
			viewBox="0 0 480 270"
			preserveAspectRatio="xMinYMid slice"
			shape-rendering="crispEdges"
			role="img"
			aria-labelledby="sceneDesc"
			data-desktop-viewbox="0 0 480 270"
			data-mobile-viewbox="0 0 200 270"
		>
			<desc id="sceneDesc">
				A pixel-art fig tree on the left of a muted landscape, with a person sitting beneath it, looking out over dithered sage hills under a dithered blue sky. Figs and fig leaves on the tree are interactive.
			</desc>

			<defs>
				<!-- Dithered sky: classic GBA/DS 2x2 checkerboard blending two
				     blues for a low-bit look. Two bands — upper and horizon —
				     give a sense of atmospheric depth. -->
				<!-- Smooth vertical sky gradient — replaces the previous multi-band
				     dither so the sky no longer shows horizontal seams. -->
				<linearGradient id="skyGrad" x1="0" x2="0" y1="0" y2="1">
					<stop offset="0" stop-color="#6a98b8" />
					<stop offset="0.22" stop-color="#82adc7" />
					<stop offset="0.48" stop-color="#a4c4d5" />
					<stop offset="0.75" stop-color="#c3d4dc" />
					<stop offset="1" stop-color="#dde2dd" />
				</linearGradient>
				<!-- Subtle 2x2 dither overlay pattern (kept for optional texture) -->
				<pattern id="skyDitherFine" width="3" height="3" patternUnits="userSpaceOnUse">
					<rect width="3" height="3" fill="transparent" />
					<rect x="0" y="0" width="1" height="1" fill="#ffffff" opacity="0.07" />
					<rect x="2" y="1" width="1" height="1" fill="#000000" opacity="0.04" />
				</pattern>
				<pattern id="skyTop" width="2" height="2" patternUnits="userSpaceOnUse">
					<rect width="2" height="2" fill="#6a98b8" />
					<rect x="0" y="0" width="1" height="1" fill="#82adc7" />
					<rect x="1" y="1" width="1" height="1" fill="#82adc7" />
				</pattern>
				<pattern id="skyHi" width="2" height="2" patternUnits="userSpaceOnUse">
					<rect width="2" height="2" fill="#7ea6c2" />
					<rect x="0" y="0" width="1" height="1" fill="#95bcd2" />
					<rect x="1" y="1" width="1" height="1" fill="#95bcd2" />
				</pattern>
				<pattern id="skyMid" width="2" height="2" patternUnits="userSpaceOnUse">
					<rect width="2" height="2" fill="#9abcce" />
					<rect x="0" y="0" width="1" height="1" fill="#b1ccda" />
					<rect x="1" y="1" width="1" height="1" fill="#b1ccda" />
				</pattern>
				<pattern id="skyLo" width="2" height="2" patternUnits="userSpaceOnUse">
					<rect width="2" height="2" fill="#b5ccd8" />
					<rect x="0" y="0" width="1" height="1" fill="#cedae2" />
					<rect x="1" y="1" width="1" height="1" fill="#cedae2" />
				</pattern>
				<pattern id="skyHaze" width="2" height="2" patternUnits="userSpaceOnUse">
					<rect width="2" height="2" fill="#d8dfe0" />
					<rect x="0" y="0" width="1" height="1" fill="#e7ebe8" />
					<rect x="1" y="1" width="1" height="1" fill="#e7ebe8" />
				</pattern>

				<!-- Dithered grass field -->
				<pattern id="grass" width="2" height="2" patternUnits="userSpaceOnUse">
					<rect width="2" height="2" fill="#6a8a4c" />
					<rect x="0" y="0" width="1" height="1" fill="#7d9e5c" />
					<rect x="1" y="1" width="1" height="1" fill="#7d9e5c" />
				</pattern>

				<!-- Mountain dithers: three distances for atmospheric perspective.
				     mountHaze = farthest, palest (barely above sky color).
				     mountFar  = main shadow side (used for left/shadow face).
				     mountLit  = main lit side (used for right face, 1 shade lighter). -->
				<pattern id="mountHaze" width="2" height="2" patternUnits="userSpaceOnUse">
					<rect width="2" height="2" fill="#a8afc1" />
					<rect x="0" y="0" width="1" height="1" fill="#b9c0cf" />
					<rect x="1" y="1" width="1" height="1" fill="#b9c0cf" />
				</pattern>
				<pattern id="mountFar" width="2" height="2" patternUnits="userSpaceOnUse">
					<rect width="2" height="2" fill="#7b839a" />
					<rect x="0" y="0" width="1" height="1" fill="#8c94a8" />
					<rect x="1" y="1" width="1" height="1" fill="#8c94a8" />
				</pattern>
				<pattern id="mountLit" width="2" height="2" patternUnits="userSpaceOnUse">
					<rect width="2" height="2" fill="#939bae" />
					<rect x="0" y="0" width="1" height="1" fill="#a5acbd" />
					<rect x="1" y="1" width="1" height="1" fill="#a5acbd" />
				</pattern>

				<!-- Three hill-distance shades: far (lightest) → mid → near (deepest) -->
				<pattern id="hillFar" width="2" height="2" patternUnits="userSpaceOnUse">
					<rect width="2" height="2" fill="#8ba17a" />
					<rect x="0" y="0" width="1" height="1" fill="#a0b68d" />
					<rect x="1" y="1" width="1" height="1" fill="#a0b68d" />
				</pattern>
				<pattern id="hillMid" width="2" height="2" patternUnits="userSpaceOnUse">
					<rect width="2" height="2" fill="#789066" />
					<rect x="0" y="0" width="1" height="1" fill="#8aa478" />
					<rect x="1" y="1" width="1" height="1" fill="#8aa478" />
				</pattern>
				<pattern id="hillNear" width="2" height="2" patternUnits="userSpaceOnUse">
					<rect width="2" height="2" fill="#5e7e50" />
					<rect x="0" y="0" width="1" height="1" fill="#6e8c5e" />
					<rect x="1" y="1" width="1" height="1" fill="#6e8c5e" />
				</pattern>

				<!-- Ripe fig pixel sprite (8x10). Integer coords only. -->
				<symbol id="ripeFig" viewBox="0 0 8 10" overflow="visible">
					<!-- stem -->
					<rect x="3" y="0" width="2" height="1" fill="#3d5220" />
					<rect x="2" y="1" width="4" height="1" fill="#5d7d35" />
					<!-- shoulders: green-yellow blotch blending into mulberry -->
					<rect x="1" y="2" width="2" height="1" fill="#8aa04c" />
					<rect x="3" y="2" width="4" height="1" fill="#6d3f52" />
					<!-- body rows getting darker -->
					<rect x="0" y="3" width="8" height="1" fill="#6d3f52" />
					<rect x="0" y="4" width="8" height="1" fill="#5a3546" />
					<rect x="0" y="5" width="8" height="1" fill="#4a2735" />
					<rect x="0" y="6" width="8" height="1" fill="#3b1c28" />
					<!-- round bottom -->
					<rect x="1" y="7" width="6" height="1" fill="#3b1c28" />
					<rect x="2" y="8" width="4" height="1" fill="#2a1020" />
					<rect x="3" y="9" width="2" height="1" fill="#1a0814" />
					<!-- highlight pixels (upper-left, catches the light) -->
					<rect x="1" y="3" width="1" height="1" fill="#8a6a7c" />
					<rect x="1" y="4" width="1" height="1" fill="#775a6c" />
				</symbol>

				<!-- Fig leaf pixel sprite (12x12): 3-lobed palmate. -->
				<symbol id="figLeaf" viewBox="0 0 12 12" overflow="visible">
					<!-- center lobe (tallest) -->
					<rect x="5" y="0" width="2" height="1" fill="#4a6a2e" />
					<rect x="4" y="1" width="4" height="2" fill="#557a35" />
					<!-- left lobe -->
					<rect x="1" y="1" width="2" height="1" fill="#4a6a2e" />
					<rect x="0" y="2" width="3" height="2" fill="#557a35" />
					<!-- right lobe -->
					<rect x="9" y="1" width="2" height="1" fill="#4a6a2e" />
					<rect x="9" y="2" width="3" height="2" fill="#557a35" />
					<!-- upper-body merge -->
					<rect x="2" y="3" width="8" height="1" fill="#557a35" />
					<rect x="1" y="4" width="10" height="2" fill="#557a35" />
					<!-- lower body -->
					<rect x="2" y="6" width="8" height="1" fill="#4a6a2e" />
					<rect x="3" y="7" width="6" height="1" fill="#4a6a2e" />
					<rect x="4" y="8" width="4" height="1" fill="#3d5520" />
					<!-- stem -->
					<rect x="5" y="9" width="2" height="3" fill="#3d5220" />
					<!-- vein hints -->
					<rect x="5" y="3" width="1" height="5" fill="#3d5520" />
				</symbol>
			</defs>

			<!-- ========== SKY (seamless gradient + subtle pixel texture) ========== -->
			<rect width="480" height="136" fill="url(#skyGrad)" />
			<!-- Fine dither overlay for a hint of pixel-noise texture over the
			     otherwise smooth gradient (avoids the sky looking glassy). -->
			<rect width="480" height="136" fill="url(#skyDitherFine)" />

			<!-- ========== DISTANT MOUNTAINS (aerial perspective + side-shading) ==========
			     Three depth tiers: farthest haze (pale), main mountains (shadow
			     + lit halves for 3D feel), with an outline ridge pixel along
			     peaks and silhouette-breaking protrusion pixels on slopes.
			     Bases extend deep below the hill ridge so no mountain floats. -->

			<!-- Haze mountains (farthest, barely visible) -->
			<g opacity="0.85">
				<!-- Haze 1 (left) -->
				<rect x="158" y="116" width="4"  height="2" fill="url(#mountHaze)" />
				<rect x="154" y="118" width="12" height="2" fill="url(#mountHaze)" />
				<rect x="150" y="120" width="20" height="2" fill="url(#mountHaze)" />
				<rect x="146" y="122" width="28" height="2" fill="url(#mountHaze)" />
				<rect x="142" y="124" width="36" height="16" fill="url(#mountHaze)" />

				<!-- Haze 2 (center) -->
				<rect x="278" y="114" width="4"  height="2" fill="url(#mountHaze)" />
				<rect x="274" y="116" width="12" height="2" fill="url(#mountHaze)" />
				<rect x="270" y="118" width="20" height="2" fill="url(#mountHaze)" />
				<rect x="266" y="120" width="28" height="2" fill="url(#mountHaze)" />
				<rect x="262" y="122" width="36" height="2" fill="url(#mountHaze)" />
				<rect x="258" y="124" width="44" height="16" fill="url(#mountHaze)" />

				<!-- Haze 3 (right) -->
				<rect x="378" y="116" width="4"  height="2" fill="url(#mountHaze)" />
				<rect x="374" y="118" width="12" height="2" fill="url(#mountHaze)" />
				<rect x="370" y="120" width="20" height="2" fill="url(#mountHaze)" />
				<rect x="366" y="122" width="28" height="2" fill="url(#mountHaze)" />
				<rect x="362" y="124" width="36" height="16" fill="url(#mountHaze)" />
			</g>

			<!-- Mountain 2: tall central peak (peak x=224, y=104) with snow cap -->
			<g>
				<rect x="223" y="104" width="1"  height="2" fill="url(#mountFar)" />
				<rect x="220" y="106" width="4"  height="2" fill="url(#mountFar)" />
				<rect x="217" y="108" width="7"  height="2" fill="url(#mountFar)" />
				<rect x="214" y="110" width="10" height="2" fill="url(#mountFar)" />
				<rect x="211" y="112" width="13" height="2" fill="url(#mountFar)" />
				<rect x="208" y="114" width="16" height="2" fill="url(#mountFar)" />
				<rect x="205" y="116" width="19" height="2" fill="url(#mountFar)" />
				<rect x="202" y="118" width="22" height="2" fill="url(#mountFar)" />
				<rect x="199" y="120" width="25" height="2" fill="url(#mountFar)" />
				<rect x="196" y="122" width="28" height="2" fill="url(#mountFar)" />
				<rect x="193" y="124" width="31" height="16" fill="url(#mountFar)" />
			</g>
			<g>
				<rect x="224" y="104" width="1"  height="2" fill="url(#mountLit)" />
				<rect x="224" y="106" width="4"  height="2" fill="url(#mountLit)" />
				<rect x="224" y="108" width="7"  height="2" fill="url(#mountLit)" />
				<rect x="224" y="110" width="10" height="2" fill="url(#mountLit)" />
				<rect x="224" y="112" width="13" height="2" fill="url(#mountLit)" />
				<rect x="224" y="114" width="16" height="2" fill="url(#mountLit)" />
				<rect x="224" y="116" width="19" height="2" fill="url(#mountLit)" />
				<rect x="224" y="118" width="22" height="2" fill="url(#mountLit)" />
				<rect x="224" y="120" width="25" height="2" fill="url(#mountLit)" />
				<rect x="224" y="122" width="28" height="2" fill="url(#mountLit)" />
				<rect x="224" y="124" width="31" height="16" fill="url(#mountLit)" />
			</g>
			<!-- snow cap -->
			<rect x="223" y="103" width="2" height="2" fill="#e6e9ec" />
			<rect x="221" y="105" width="2" height="1" fill="#e6e9ec" />
			<rect x="225" y="105" width="3" height="1" fill="#e6e9ec" />
			<rect x="219" y="107" width="2" height="1" fill="#e6e9ec" />
			<rect x="227" y="107" width="2" height="1" fill="#e6e9ec" />

			<!-- Mountain 3: right of center (peak x=340, y=112) -->
			<g>
				<rect x="339" y="112" width="1"  height="2" fill="url(#mountFar)" />
				<rect x="336" y="114" width="4"  height="2" fill="url(#mountFar)" />
				<rect x="332" y="116" width="8"  height="2" fill="url(#mountFar)" />
				<rect x="328" y="118" width="12" height="2" fill="url(#mountFar)" />
				<rect x="324" y="120" width="16" height="2" fill="url(#mountFar)" />
				<rect x="320" y="122" width="20" height="2" fill="url(#mountFar)" />
				<rect x="316" y="124" width="24" height="16" fill="url(#mountFar)" />
			</g>
			<g>
				<rect x="340" y="112" width="1"  height="2" fill="url(#mountLit)" />
				<rect x="340" y="114" width="4"  height="2" fill="url(#mountLit)" />
				<rect x="340" y="116" width="8"  height="2" fill="url(#mountLit)" />
				<rect x="340" y="118" width="12" height="2" fill="url(#mountLit)" />
				<rect x="340" y="120" width="16" height="2" fill="url(#mountLit)" />
				<rect x="340" y="122" width="20" height="2" fill="url(#mountLit)" />
				<rect x="340" y="124" width="24" height="16" fill="url(#mountLit)" />
			</g>

			<!-- Mountain 4: far right (peak x=430, y=116) — base extended far
			     enough to dip under the lowest hill columns (~y=134). -->
			<g>
				<rect x="429" y="116" width="1"  height="2" fill="url(#mountFar)" />
				<rect x="426" y="118" width="4"  height="2" fill="url(#mountFar)" />
				<rect x="422" y="120" width="8"  height="2" fill="url(#mountFar)" />
				<rect x="418" y="122" width="12" height="2" fill="url(#mountFar)" />
				<rect x="414" y="124" width="16" height="2" fill="url(#mountFar)" />
				<rect x="411" y="126" width="19" height="2" fill="url(#mountFar)" />
				<rect x="408" y="128" width="22" height="2" fill="url(#mountFar)" />
				<rect x="406" y="130" width="24" height="12" fill="url(#mountFar)" />
			</g>
			<g>
				<rect x="430" y="116" width="1"  height="2" fill="url(#mountLit)" />
				<rect x="430" y="118" width="4"  height="2" fill="url(#mountLit)" />
				<rect x="430" y="120" width="8"  height="2" fill="url(#mountLit)" />
				<rect x="430" y="122" width="12" height="2" fill="url(#mountLit)" />
				<rect x="430" y="124" width="16" height="2" fill="url(#mountLit)" />
				<rect x="430" y="126" width="19" height="2" fill="url(#mountLit)" />
				<rect x="430" y="128" width="22" height="2" fill="url(#mountLit)" />
				<rect x="430" y="130" width="24" height="12" fill="url(#mountLit)" />
			</g>

			<!-- ========== CLOUDS (gap-free, body-first, multi-lobe) ==========
			     Each cloud is painted as a solid body rect first, then lobe
			     bumps on top, then shadow rows on bottom — so the silhouette
			     is always continuous (no visible gaps between lobes). -->

			<!-- Cloud A: big three-lobe cumulus, upper-center -->
			<g class="drift drift-a">
				<!-- Solid body (ensures no gaps beneath the lobes) -->
				<rect x="248" y="14" width="72" height="12" fill="#ffffff" />
				<!-- Left lobe bump -->
				<rect x="254" y="12" width="14" height="2" fill="#ffffff" />
				<rect x="256" y="10" width="10" height="2" fill="#ffffff" />
				<rect x="258" y="9"  width="6"  height="1" fill="#ffffff" />
				<!-- Middle lobe bump (tallest) -->
				<rect x="278" y="10" width="20" height="4" fill="#ffffff" />
				<rect x="280" y="8"  width="16" height="2" fill="#ffffff" />
				<rect x="282" y="7"  width="12" height="1" fill="#ffffff" />
				<rect x="284" y="6"  width="8"  height="1" fill="#ffffff" />
				<!-- Right lobe bump -->
				<rect x="302" y="12" width="14" height="2" fill="#ffffff" />
				<rect x="304" y="10" width="10" height="2" fill="#ffffff" />
				<rect x="306" y="9"  width="6"  height="1" fill="#ffffff" />
				<!-- Side fluff bumps -->
				<rect x="246" y="18" width="2"  height="6" fill="#ffffff" />
				<rect x="320" y="18" width="2"  height="6" fill="#ffffff" />
				<rect x="244" y="20" width="2"  height="2" fill="#ffffff" />
				<rect x="322" y="20" width="2"  height="2" fill="#ffffff" />
				<!-- Underside shadow tiers -->
				<rect x="250" y="26" width="68" height="1" fill="#d2dde5" />
				<rect x="256" y="27" width="58" height="1" fill="#b2c3d0" />
				<rect x="264" y="28" width="42" height="1" fill="#93a5b6" />
			</g>

			<!-- Cloud B: medium two-lobe, right side -->
			<g class="drift drift-b">
				<!-- Body -->
				<rect x="378" y="40" width="44" height="6" fill="#ffffff" />
				<!-- Left lobe bump -->
				<rect x="382" y="38" width="14" height="2" fill="#ffffff" />
				<rect x="384" y="36" width="10" height="2" fill="#ffffff" />
				<rect x="386" y="35" width="6"  height="1" fill="#ffffff" />
				<!-- Right lobe bump (smaller) -->
				<rect x="400" y="38" width="18" height="2" fill="#ffffff" />
				<rect x="402" y="36" width="14" height="2" fill="#ffffff" />
				<rect x="404" y="35" width="10" height="1" fill="#ffffff" />
				<!-- Side bumps -->
				<rect x="376" y="42" width="2"  height="3" fill="#ffffff" />
				<rect x="422" y="42" width="2"  height="3" fill="#ffffff" />
				<!-- Shadow tiers -->
				<rect x="380" y="46" width="40" height="1" fill="#c8d5df" />
				<rect x="386" y="47" width="28" height="1" fill="#a2b3c2" />
			</g>

			<!-- Cloud C: medium puff, far-right lower (enlarged) -->
			<g class="drift drift-c">
				<rect x="432" y="68" width="28" height="6" fill="#ffffff" />
				<rect x="436" y="66" width="18" height="2" fill="#ffffff" />
				<rect x="438" y="65" width="12" height="1" fill="#ffffff" />
				<rect x="430" y="70" width="2"  height="3" fill="#ffffff" />
				<rect x="460" y="70" width="2"  height="3" fill="#ffffff" />
				<rect x="434" y="74" width="24" height="1" fill="#c8d5df" />
				<rect x="438" y="75" width="16" height="1" fill="#a2b3c2" />
			</g>

			<!-- Cloud D: two-lobe puff, left-of-center (enlarged) -->
			<g class="drift drift-a">
				<rect x="136" y="84" width="36" height="6" fill="#ffffff" />
				<rect x="140" y="82" width="14" height="2" fill="#ffffff" />
				<rect x="142" y="81" width="8"  height="1" fill="#ffffff" />
				<rect x="156" y="82" width="12" height="2" fill="#ffffff" />
				<rect x="158" y="81" width="6"  height="1" fill="#ffffff" />
				<rect x="134" y="86" width="2"  height="3" fill="#ffffff" />
				<rect x="172" y="86" width="2"  height="3" fill="#ffffff" />
				<rect x="138" y="90" width="32" height="1" fill="#c8d5df" />
				<rect x="144" y="91" width="22" height="1" fill="#a2b3c2" />
			</g>

			<!-- Cloud E: medium tuft, upper-left (enlarged from prior tiny) -->
			<g class="drift drift-b">
				<rect x="40" y="30" width="32" height="6" fill="#ffffff" />
				<rect x="44" y="28" width="14" height="2" fill="#ffffff" />
				<rect x="46" y="27" width="8"  height="1" fill="#ffffff" />
				<rect x="60" y="28" width="10" height="2" fill="#ffffff" />
				<rect x="62" y="27" width="4"  height="1" fill="#ffffff" />
				<rect x="38" y="32" width="2"  height="3" fill="#ffffff" />
				<rect x="72" y="32" width="2"  height="3" fill="#ffffff" />
				<rect x="42" y="36" width="28" height="1" fill="#c8d5df" />
				<rect x="48" y="37" width="18" height="1" fill="#a2b3c2" />
			</g>

			<!-- ========== FOREGROUND HILL (one rolling form — Bliss-style) ==========
			     The whole ground is one continuous grass silhouette. Its TOP
			     edge is the horizon line, drawn as pixel columns of varying
			     height so the ridge rolls up and down gently. Below the ridge
			     the grass pattern extends to the bottom of the scene. No
			     stacked hill bands, no horizon haze strip. -->
			<g>
				<!-- Fine-grained hill columns (~8-10 px wide each) with small
				     1-2 px y-steps between adjacent columns, so the horizon
				     reads as a gentle curve instead of a chunky staircase. -->
				<rect x="0"   y="135" width="8"  height="135" fill="url(#grass)" />
				<rect x="8"   y="133" width="6"  height="137" fill="url(#grass)" />
