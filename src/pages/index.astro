---
import Base from '../layouts/Base.astro';
import RetroWindow from '../components/RetroWindow.astro';

// Pixel-art scene, Pokémon Emerald / Black-&-White inspired.
// ViewBox is a small 480x270 and everything is drawn on integer pixel
// coordinates; shape-rendering="crispEdges" + CSS image-rendering:pixelated
// preserves the chunky look at any viewport size.
---

<Base>
	<div class="scene" id="scene" role="main" aria-label="figtre.es home scene">
		<svg
			class="landscape"
			viewBox="0 0 480 270"
			preserveAspectRatio="xMinYMid slice"
			shape-rendering="crispEdges"
			role="img"
			aria-labelledby="sceneDesc"
			data-desktop-viewbox="0 0 480 270"
			data-mobile-viewbox="0 0 200 270"
		>
			<desc id="sceneDesc">
				A pixel-art fig tree on the left of a muted landscape, with a person sitting beneath it, looking out over dithered sage hills under a dithered blue sky. Figs and fig leaves on the tree are interactive.
			</desc>

			<defs>
				<!-- Dithered sky: classic GBA/DS 2x2 checkerboard blending two
				     blues for a low-bit look. Two bands — upper and horizon —
				     give a sense of atmospheric depth. -->
				<pattern id="skyHi" width="2" height="2" patternUnits="userSpaceOnUse">
					<rect width="2" height="2" fill="#7ea6c2" />
					<rect x="0" y="0" width="1" height="1" fill="#95bcd2" />
					<rect x="1" y="1" width="1" height="1" fill="#95bcd2" />
				</pattern>
				<pattern id="skyLo" width="2" height="2" patternUnits="userSpaceOnUse">
					<rect width="2" height="2" fill="#b5ccd8" />
					<rect x="0" y="0" width="1" height="1" fill="#cedae2" />
					<rect x="1" y="1" width="1" height="1" fill="#cedae2" />
				</pattern>

				<!-- Dithered grass field -->
				<pattern id="grass" width="2" height="2" patternUnits="userSpaceOnUse">
					<rect width="2" height="2" fill="#6a8a4c" />
					<rect x="0" y="0" width="1" height="1" fill="#7d9e5c" />
					<rect x="1" y="1" width="1" height="1" fill="#7d9e5c" />
				</pattern>

				<!-- Dithered far + mid hill shades -->
				<pattern id="hillFar" width="2" height="2" patternUnits="userSpaceOnUse">
					<rect width="2" height="2" fill="#8ba17a" />
					<rect x="0" y="0" width="1" height="1" fill="#a0b68d" />
					<rect x="1" y="1" width="1" height="1" fill="#a0b68d" />
				</pattern>
				<pattern id="hillMid" width="2" height="2" patternUnits="userSpaceOnUse">
					<rect width="2" height="2" fill="#789066" />
					<rect x="0" y="0" width="1" height="1" fill="#8aa478" />
					<rect x="1" y="1" width="1" height="1" fill="#8aa478" />
				</pattern>

				<!-- Ripe fig pixel sprite (8x10). Integer coords only. -->
				<symbol id="ripeFig" viewBox="0 0 8 10" overflow="visible">
					<!-- stem -->
					<rect x="3" y="0" width="2" height="1" fill="#3d5220" />
					<rect x="2" y="1" width="4" height="1" fill="#5d7d35" />
					<!-- shoulders: green-yellow blotch blending into mulberry -->
					<rect x="1" y="2" width="2" height="1" fill="#8aa04c" />
					<rect x="3" y="2" width="4" height="1" fill="#6d3f52" />
					<!-- body rows getting darker -->
					<rect x="0" y="3" width="8" height="1" fill="#6d3f52" />
					<rect x="0" y="4" width="8" height="1" fill="#5a3546" />
					<rect x="0" y="5" width="8" height="1" fill="#4a2735" />
					<rect x="0" y="6" width="8" height="1" fill="#3b1c28" />
					<!-- round bottom -->
					<rect x="1" y="7" width="6" height="1" fill="#3b1c28" />
					<rect x="2" y="8" width="4" height="1" fill="#2a1020" />
					<rect x="3" y="9" width="2" height="1" fill="#1a0814" />
					<!-- highlight pixels (upper-left, catches the light) -->
					<rect x="1" y="3" width="1" height="1" fill="#8a6a7c" />
					<rect x="1" y="4" width="1" height="1" fill="#775a6c" />
				</symbol>

				<!-- Fig leaf pixel sprite (12x12): 3-lobed palmate. -->
				<symbol id="figLeaf" viewBox="0 0 12 12" overflow="visible">
					<!-- center lobe (tallest) -->
					<rect x="5" y="0" width="2" height="1" fill="#4a6a2e" />
					<rect x="4" y="1" width="4" height="2" fill="#557a35" />
					<!-- left lobe -->
					<rect x="1" y="1" width="2" height="1" fill="#4a6a2e" />
					<rect x="0" y="2" width="3" height="2" fill="#557a35" />
					<!-- right lobe -->
					<rect x="9" y="1" width="2" height="1" fill="#4a6a2e" />
					<rect x="9" y="2" width="3" height="2" fill="#557a35" />
					<!-- upper-body merge -->
					<rect x="2" y="3" width="8" height="1" fill="#557a35" />
					<rect x="1" y="4" width="10" height="2" fill="#557a35" />
					<!-- lower body -->
					<rect x="2" y="6" width="8" height="1" fill="#4a6a2e" />
					<rect x="3" y="7" width="6" height="1" fill="#4a6a2e" />
					<rect x="4" y="8" width="4" height="1" fill="#3d5520" />
					<!-- stem -->
					<rect x="5" y="9" width="2" height="3" fill="#3d5220" />
					<!-- vein hints -->
					<rect x="5" y="3" width="1" height="5" fill="#3d5520" />
				</symbol>
			</defs>

			<!-- ========== SKY ========== -->
			<rect width="480" height="90" fill="url(#skyHi)" />
			<rect y="90" width="480" height="40" fill="url(#skyLo)" />

			<!-- ========== CLOUDS (pixel-stacked) ========== -->
			<g class="drift drift-a" fill="#ffffff">
				<rect x="280" y="22" width="28" height="3" />
				<rect x="274" y="25" width="40" height="4" />
				<rect x="280" y="29" width="28" height="3" />
			</g>
			<rect x="282" y="32" width="24" height="1" fill="#b4c5cf" />

			<g class="drift drift-b" fill="#ffffff">
				<rect x="380" y="40" width="22" height="3" />
				<rect x="376" y="43" width="32" height="4" />
				<rect x="380" y="47" width="22" height="3" />
			</g>
			<rect x="380" y="50" width="22" height="1" fill="#b4c5cf" />

			<g class="drift drift-c" fill="#ffffff">
				<rect x="356" y="70" width="20" height="2" />
				<rect x="352" y="72" width="28" height="3" />
				<rect x="356" y="75" width="20" height="2" />
			</g>

			<!-- ========== HILLS ========== -->
			<!-- Far hill (light sage) -->
			<g>
				<rect x="0" y="130" width="80" height="40" fill="url(#hillFar)" />
				<rect x="0" y="126" width="50" height="4" fill="url(#hillFar)" />
				<rect x="80" y="134" width="80" height="36" fill="url(#hillFar)" />
				<rect x="120" y="130" width="40" height="4" fill="url(#hillFar)" />
				<rect x="160" y="132" width="100" height="38" fill="url(#hillFar)" />
				<rect x="200" y="128" width="60" height="4" fill="url(#hillFar)" />
				<rect x="260" y="136" width="100" height="34" fill="url(#hillFar)" />
				<rect x="300" y="132" width="40" height="4" fill="url(#hillFar)" />
				<rect x="360" y="130" width="120" height="40" fill="url(#hillFar)" />
				<rect x="410" y="126" width="50" height="4" fill="url(#hillFar)" />
			</g>
			<!-- Distant tree silhouettes on far hill (tiny stepped shapes) -->
			<g fill="#5e7550">
				<rect x="186" y="126" width="3" height="4" />
				<rect x="185" y="128" width="5" height="2" />
				<rect x="260" y="132" width="3" height="4" />
				<rect x="392" y="126" width="4" height="4" />
				<rect x="391" y="128" width="6" height="2" />
			</g>
			<!-- Mid hill (deeper sage, overlaps closer ground) -->
			<g>
				<rect x="80" y="146" width="100" height="40" fill="url(#hillMid)" />
				<rect x="120" y="142" width="40" height="4" fill="url(#hillMid)" />
				<rect x="180" y="150" width="120" height="36" fill="url(#hillMid)" />
				<rect x="220" y="146" width="40" height="4" fill="url(#hillMid)" />
				<rect x="300" y="148" width="180" height="38" fill="url(#hillMid)" />
				<rect x="360" y="144" width="60" height="4" fill="url(#hillMid)" />
			</g>

			<!-- ========== GRASS FIELD ========== -->
			<rect y="160" width="480" height="110" fill="url(#grass)" />
			<!-- scattered dark grass blade pixels for depth -->
			<g fill="#4a6634">
				<rect x="40" y="190" width="1" height="2" />
				<rect x="68" y="200" width="1" height="2" />
				<rect x="110" y="210" width="1" height="2" />
				<rect x="140" y="224" width="1" height="2" />
				<rect x="172" y="196" width="1" height="2" />
				<rect x="204" y="214" width="1" height="2" />
				<rect x="240" y="202" width="1" height="2" />
				<rect x="268" y="232" width="1" height="2" />
				<rect x="300" y="218" width="1" height="2" />
				<rect x="340" y="244" width="1" height="2" />
				<rect x="370" y="224" width="1" height="2" />
				<rect x="408" y="198" width="1" height="2" />
				<rect x="436" y="232" width="1" height="2" />
				<rect x="84" y="250" width="1" height="2" />
				<rect x="180" y="256" width="1" height="2" />
				<rect x="264" y="262" width="1" height="2" />
				<rect x="356" y="248" width="1" height="2" />
			</g>
			<!-- a few lighter grass dabs (catching sun) -->
			<g fill="#9ab870">
				<rect x="58" y="196" width="1" height="1" />
				<rect x="130" y="218" width="1" height="1" />
				<rect x="244" y="208" width="1" height="1" />
				<rect x="348" y="230" width="1" height="1" />
				<rect x="420" y="210" width="1" height="1" />
			</g>

			<!-- =========================================================
			     TREE + PERSON + HOTSPOTS (shifted slightly down-left)
			     ========================================================= -->
			<g class="tree-shift" transform="translate(-8 4)">
				<!-- ground shadow under tree -->
				<rect x="52" y="162" width="52" height="2" fill="#4a6634" opacity="0.55" />

				<!-- Trunk: stepped pixel shape -->
				<g>
					<!-- base (wider, rooting into ground) -->
					<rect x="54" y="154" width="48" height="8" fill="#3a2614" />
					<rect x="56" y="150" width="44" height="4" fill="#4a3020" />
					<!-- body, gradually narrower going up -->
					<rect x="60" y="120" width="36" height="30" fill="#4a3020" />
					<rect x="62" y="90" width="32" height="30" fill="#4a3020" />
					<rect x="64" y="60" width="28" height="30" fill="#4a3020" />
					<rect x="66" y="40" width="24" height="20" fill="#4a3020" />
					<!-- bark highlight column (left side) -->
					<rect x="60" y="120" width="3" height="30" fill="#5e3f2a" />
					<rect x="62" y="90" width="3" height="30" fill="#5e3f2a" />
					<rect x="64" y="60" width="3" height="30" fill="#5e3f2a" />
					<rect x="66" y="40" width="3" height="20" fill="#5e3f2a" />
					<!-- bark shadow column (right side) -->
					<rect x="92" y="120" width="4" height="30" fill="#2a1a0e" />
					<rect x="90" y="90" width="4" height="30" fill="#2a1a0e" />
					<rect x="88" y="60" width="4" height="30" fill="#2a1a0e" />
					<rect x="86" y="40" width="4" height="20" fill="#2a1a0e" />
					<!-- bark knots -->
					<rect x="72" y="100" width="2" height="2" fill="#1a0e06" />
					<rect x="82" y="130" width="2" height="2" fill="#1a0e06" />
					<rect x="76" y="70" width="2" height="2" fill="#1a0e06" />
					<!-- subtle bark streaks -->
					<rect x="74" y="120" width="1" height="20" fill="#3a2614" />
					<rect x="82" y="80" width="1" height="30" fill="#3a2614" />
				</g>

				<!-- Canopy: blocky stacked blobs with stepped edges -->
				<g class="canopy">
					<!-- back dark mass -->
					<rect x="26" y="28" width="112" height="40" fill="#2e4020" />
					<rect x="22" y="34" width="120" height="28" fill="#2e4020" />
					<rect x="30" y="22" width="100" height="6" fill="#2e4020" />
					<rect x="38" y="16" width="84" height="6" fill="#2e4020" />
					<rect x="18" y="42" width="128" height="18" fill="#2e4020" />
					<rect x="26" y="60" width="112" height="8" fill="#2e4020" />
					<rect x="36" y="68" width="92" height="4" fill="#2e4020" />
					<!-- mid green -->
					<rect x="30" y="30" width="104" height="30" fill="#3d5830" />
					<rect x="26" y="38" width="112" height="20" fill="#3d5830" />
					<rect x="34" y="24" width="88" height="6" fill="#3d5830" />
					<rect x="42" y="18" width="76" height="6" fill="#3d5830" />
					<rect x="22" y="46" width="120" height="12" fill="#3d5830" />
					<rect x="30" y="58" width="104" height="4" fill="#3d5830" />
					<!-- highlight band (sun-lit upper-left) -->
					<rect x="42" y="24" width="60" height="6" fill="#5a7d46" />
					<rect x="38" y="30" width="70" height="4" fill="#5a7d46" />
					<rect x="50" y="18" width="40" height="6" fill="#5a7d46" />
					<rect x="28" y="42" width="24" height="6" fill="#5a7d46" />
					<rect x="34" y="48" width="16" height="4" fill="#5a7d46" />

					<!-- Individual pixel fig leaves on the canopy rim -->
					<g>
						<!-- top lobes -->
						<use href="#figLeaf" x="34" y="6" width="12" height="12" />
						<use href="#figLeaf" x="56" y="2" width="12" height="12" />
						<use href="#figLeaf" x="82" y="2" width="12" height="12" />
						<use href="#figLeaf" x="106" y="6" width="12" height="12" />
						<!-- sides -->
						<use href="#figLeaf" x="16" y="18" width="12" height="12" />
						<use href="#figLeaf" x="126" y="18" width="12" height="12" />
						<use href="#figLeaf" x="10" y="36" width="12" height="12" />
						<use href="#figLeaf" x="134" y="36" width="12" height="12" />
						<!-- bottom -->
						<use href="#figLeaf" x="22" y="58" width="12" height="12" />
						<use href="#figLeaf" x="50" y="64" width="12" height="12" />
						<use href="#figLeaf" x="82" y="62" width="12" height="12" />
						<use href="#figLeaf" x="112" y="58" width="12" height="12" />
					</g>
				</g>

				<!-- Static decorative figs on the tree -->
				<g class="decor-figs">
					<use href="#ripeFig" x="48" y="38" width="8" height="10" transform="rotate(-14 52 43)" />
					<use href="#ripeFig" x="94" y="34" width="8" height="10" transform="rotate(10 98 39)" />
					<use href="#ripeFig" x="72" y="52" width="8" height="10" transform="rotate(-7 76 57)" />
					<use href="#ripeFig" x="114" y="50" width="8" height="10" transform="rotate(15 118 55)" />
					<use href="#ripeFig" x="36" y="54" width="8" height="10" transform="rotate(-18 40 59)" />
				</g>

				<!-- Person: Pokémon-style overworld pixel sprite, sitting -->
				<g transform="translate(96 132)">
					<!-- ground shadow -->
					<rect x="-2" y="30" width="30" height="2" fill="#4a6634" opacity="0.55" />
					<!-- hair top -->
					<rect x="4" y="0" width="8" height="2" fill="#1a100a" />
					<rect x="3" y="2" width="1" height="2" fill="#1a100a" />
					<rect x="12" y="2" width="1" height="3" fill="#1a100a" />
					<!-- head (skin) -->
					<rect x="4" y="2" width="8" height="5" fill="#d9a57c" />
					<!-- hair bangs -->
					<rect x="4" y="2" width="2" height="1" fill="#1a100a" />
					<rect x="10" y="2" width="2" height="1" fill="#1a100a" />
					<!-- eye -->
					<rect x="10" y="4" width="1" height="2" fill="#1a100a" />
					<!-- face shadow -->
					<rect x="4" y="6" width="8" height="1" fill="#b88660" />
					<!-- neck -->
					<rect x="6" y="7" width="5" height="1" fill="#b88660" />
					<!-- torso (olive shirt) -->
					<rect x="2" y="8" width="13" height="7" fill="#5d7944" />
					<!-- shirt collar shadow -->
					<rect x="5" y="8" width="7" height="1" fill="#46593a" />
					<!-- arm resting on bent knee (shirt then skin) -->
					<rect x="14" y="11" width="6" height="2" fill="#5d7944" />
					<rect x="18" y="13" width="4" height="2" fill="#b88660" />
					<!-- shirt bottom shadow band -->
					<rect x="2" y="14" width="13" height="1" fill="#46593a" />
					<!-- bent front leg (pants) -->
					<rect x="4" y="15" width="8" height="2" fill="#2a2117" />
					<!-- extended leg going right -->
					<rect x="12" y="15" width="12" height="3" fill="#2a2117" />
					<rect x="16" y="18" width="10" height="2" fill="#2a2117" />
					<!-- shoes -->
					<rect x="24" y="18" width="4" height="3" fill="#1a0e06" />
					<rect x="4" y="17" width="8" height="2" fill="#1a0e06" />
				</g>

				<!-- =========================================================
				     CLICKABLE HOTSPOTS — pixel figs + leaves
				     ========================================================= -->
				<g class="leaves">
					<!-- notes: upper-right leaf, enlarged 2x with rotation -->
					<g class="hotspot hotspot-leaf" data-window="notes" tabindex="0" role="button" aria-label="Open notes">
						<title>notes</title>
						<use href="#figLeaf" x="132" y="4" width="20" height="20" transform="rotate(30 142 14)" />
						<rect x="126" y="-2" width="32" height="32" fill="transparent" />
					</g>
					<!-- contact: upper-left leaf -->
					<g class="hotspot hotspot-leaf" data-window="contact" tabindex="0" role="button" aria-label="Open contact">
						<title>contact</title>
						<use href="#figLeaf" x="2" y="20" width="20" height="20" transform="rotate(-40 12 30)" />
						<rect x="-4" y="14" width="32" height="32" fill="transparent" />
					</g>
				</g>

				<g class="figs">
					<!-- about: continuously pulsing, sized larger than decor figs -->
					<g class="hotspot hotspot-pulse" data-window="about" tabindex="0" role="button" aria-label="Open about">
						<title>about</title>
						<g class="pulse-target" transform="translate(60 38)">
							<use href="#ripeFig" x="-7" y="-8" width="14" height="18" transform="rotate(6 0 1)" />
						</g>
						<rect x="50" y="28" width="20" height="24" fill="transparent" />
					</g>
					<!-- projects -->
					<g class="hotspot" data-window="projects" tabindex="0" role="button" aria-label="Open projects">
						<title>projects</title>
						<g transform="translate(34 66)">
							<use href="#ripeFig" x="-7" y="-8" width="14" height="18" transform="rotate(-14 0 1)" />
						</g>
						<rect x="24" y="56" width="20" height="24" fill="transparent" />
					</g>
					<!-- now -->
					<g class="hotspot" data-window="now" tabindex="0" role="button" aria-label="Open now">
						<title>now</title>
						<g transform="translate(108 60)">
							<use href="#ripeFig" x="-7" y="-8" width="14" height="18" transform="rotate(13 0 1)" />
						</g>
						<rect x="98" y="50" width="20" height="24" fill="transparent" />
					</g>
				</g>
			</g>
		</svg>

		<!-- Windows -->
		<RetroWindow id="about" title="about" x={720} y={120} ackLabel="Ack">
			<p><em>a personal corner</em></p>
			<p>Tended by Alex. Fig-themed because the fig trees in the backyard are louder than they seem.</p>
		</RetroWindow>

		<RetroWindow id="notes" title="notes" x={780} y={200} ackLabel="Ack">
			<p>Short entries, planted as they come.</p>
			<p><a href="/notes">open /notes &rarr;</a></p>
		</RetroWindow>

		<RetroWindow id="projects" title="projects" x={840} y={280} ackLabel="Ack">
			<p>Things I'm growing.</p>
			<p><em>More soon.</em></p>
		</RetroWindow>

		<RetroWindow id="contact" title="contact" x={900} y={360} ackLabel="Ack">
			<p>Reach out.</p>
			<p><a href="mailto:alexlu876@gmail.com">alexlu876@gmail.com</a></p>
		</RetroWindow>

		<RetroWindow id="now" title="now" x={960} y={440} ackLabel="Ack">
			<p>Planting seeds. Watering the fig tree. Writing things down.</p>
		</RetroWindow>
	</div>
</Base>

<style>
	.scene {
		position: relative;
		width: 100vw;
		height: 100vh;
		overflow: hidden;
		background: #7ea6c2;
	}
	@media (max-width: 640px) {
		.scene {
			background: linear-gradient(to bottom, #7ea6c2 0%, #b5ccd8 45%, #8aa478 55%, #6a8a4c 100%);
		}
	}
	.landscape {
		width: 100%;
		height: 100%;
		display: block;
		/* Render the scaled-up SVG with nearest-neighbor so the pixel
		   aesthetic holds at any viewport size. */
		image-rendering: pixelated;
		image-rendering: -moz-crisp-edges;
		image-rendering: crisp-edges;
	}
	.hotspot {
		cursor: pointer;
		transition: filter 140ms ease, transform 140ms ease;
		transform-box: fill-box;
		transform-origin: center;
	}
	.hotspot:hover {
		filter: brightness(1.2) drop-shadow(1px 1px 0 #f4e3a8);
		transform: scale(1.12);
	}
	.hotspot:focus { outline: none; }
	.hotspot:focus-visible {
		filter: brightness(1.22);
		outline: 2px dashed #f4e3a8;
		outline-offset: 2px;
	}
	/* Small warm pixel shadow on interactive leaves */
	.hotspot-leaf use { filter: drop-shadow(1px 1px 0 #3d5220); }

	@keyframes breathe {
		0%   { transform: scale(1); }
		50%  { transform: scale(1.12); }
		100% { transform: scale(1); }
	}
	.hotspot-pulse .pulse-target {
		transform-box: fill-box;
		transform-origin: center;
		animation: breathe 3.2s steps(4, end) infinite;
	}
	.hotspot-pulse:hover .pulse-target { animation-play-state: paused; }

	@keyframes pssst {
		0%   { transform: translate(0, 0); }
		25%  { transform: translate(0, -1px); }
		50%  { transform: translate(0, 1px); }
		100% { transform: translate(0, 0); }
	}
	.hotspot.pssst {
		transform-box: fill-box;
		transform-origin: center;
		animation: pssst 1.2s steps(4, end) 1;
	}
	@media (prefers-reduced-motion: reduce) {
		.hotspot-pulse .pulse-target { animation: none; }
		.hotspot.pssst { animation: none; }
		.drift-a, .drift-b, .drift-c { animation: none; }
	}

	/* Very slow cloud drift — small pixel-step offsets so it still feels
	   tile-based rather than continuous. */
	@keyframes driftA { from { transform: translateX(0); } to { transform: translateX(10px); } }
	@keyframes driftB { from { transform: translateX(0); } to { transform: translateX(-8px); } }
	@keyframes driftC { from { transform: translateX(0); } to { transform: translateX(6px); } }
	.drift-a { animation: driftA 80s steps(10, end) infinite alternate; }
	.drift-b { animation: driftB 100s steps(8, end) infinite alternate; }
	.drift-c { animation: driftC 120s steps(6, end) infinite alternate; }
</style>

<script>
	const scene = document.getElementById('scene');
	if (scene) {
		let topZ = 10;

		// Mobile: zoom into the left portion of the scene so the tree fills
		// the narrow viewport instead of the sky dominating.
		const svg = scene.querySelector<SVGSVGElement>('svg.landscape');
		const mobileQuery = window.matchMedia('(max-width: 640px)');
		const applyMobileScene = (isMobile: boolean) => {
			if (!svg) return;
			const desktopVB = svg.dataset.desktopViewbox || '0 0 480 270';
			const mobileVB = svg.dataset.mobileViewbox || '0 0 200 270';
			svg.setAttribute('viewBox', isMobile ? mobileVB : desktopVB);
			svg.setAttribute(
				'preserveAspectRatio',
				isMobile ? 'xMidYMid meet' : 'xMinYMid slice',
			);
		};
		applyMobileScene(mobileQuery.matches);
		if ('addEventListener' in mobileQuery) {
			mobileQuery.addEventListener('change', (e) => applyMobileScene(e.matches));
		}

		const bringToFront = (el: HTMLElement) => {
			topZ += 1;
			el.style.zIndex = String(topZ);
		};

		const openWindow = (id: string) => {
			const win = document.getElementById(`window-${id}`) as HTMLElement | null;
			if (!win) return;
			win.hidden = false;
			bringToFront(win);
		};

		const hotspots = scene.querySelectorAll<SVGElement>('.hotspot');
		hotspots.forEach((el) => {
			const id = (el as SVGElement & { dataset: DOMStringMap }).dataset.window;
			if (!id) return;
			el.addEventListener('click', () => openWindow(id));
			el.addEventListener('keydown', (e) => {
				const ke = e as KeyboardEvent;
				if (ke.key === 'Enter' || ke.key === ' ') {
					ke.preventDefault();
					openWindow(id);
				}
			});
		});

		// One-shot pssst bob ~1.8s after load
		const rm = window.matchMedia('(prefers-reduced-motion: reduce)');
		if (!rm.matches) {
			window.setTimeout(() => {
				hotspots.forEach((el, i) => {
					window.setTimeout(() => {
						el.classList.add('pssst');
						el.addEventListener(
							'animationend',
							() => el.classList.remove('pssst'),
							{ once: true }
						);
					}, i * 120);
				});
			}, 1800);
		}

		const mobileMq = window.matchMedia('(max-width: 640px)');
		scene.querySelectorAll<HTMLElement>('.window').forEach((win) => {
			win.addEventListener('mousedown', () => bringToFront(win));

			win.querySelectorAll<HTMLButtonElement>('[data-close]').forEach((btn) => {
				btn.addEventListener('click', () => {
					win.hidden = true;
				});
			});

			const handle = win.querySelector<HTMLElement>('[data-drag-handle]');
			if (!handle) return;

			let dragging = false;
			let offsetX = 0;
			let offsetY = 0;

			handle.addEventListener('mousedown', (e) => {
				if (mobileMq.matches) return;
				if ((e.target as HTMLElement).closest('[data-close]')) return;
				dragging = true;
				const rect = win.getBoundingClientRect();
				offsetX = e.clientX - rect.left;
				offsetY = e.clientY - rect.top;
				e.preventDefault();
			});

			document.addEventListener('mousemove', (e) => {
				if (!dragging) return;
				win.style.left = `${e.clientX - offsetX}px`;
				win.style.top = `${e.clientY - offsetY}px`;
			});

			document.addEventListener('mouseup', () => {
				dragging = false;
			});
		});
	}
</script>
