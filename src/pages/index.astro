</Base>

<style>
	.scene {
		position: relative;
		width: 100vw;
		height: 100vh;
		overflow: hidden;
		background: #0a0a0a;
	}
	/* On mobile the SVG is `meet`-fit (letterboxed top/bottom) so the
	   rect background shows through. Match it to the scene's sky→hill
	   palette so the letterbox blends with the painting. */
	@media (max-width: 640px) {
		.scene {
			background: linear-gradient(
				to bottom,
				#8ca8bf 0%,
				#afc4d2 20%,
				#d6dcd6 50%,
				#8aa181 55%,
				#617955 100%
			);
		}
	}
	.landscape {
		width: 100%;
		height: 100%;
		display: block;
	}
	.hotspot {
		cursor: pointer;
		transition: filter 160ms ease, transform 160ms ease;
		transform-box: fill-box;
		transform-origin: center;
	}
	.hotspot:hover {
		filter: brightness(1.18) drop-shadow(0 0 8px rgba(255, 236, 190, 0.75));
		transform: scale(1.08);
	}
	.hotspot:focus {
		outline: none;
	}
	.hotspot:focus-visible {
		filter: brightness(1.2) drop-shadow(0 0 10px rgba(255, 236, 190, 0.9));
		transform: scale(1.06);
		outline: 2px dashed #3a5070;
		outline-offset: 4px;
	}
	/* Warm rim on interactive leaves so a user intuits they're clickable */
	.hotspot-leaf use {
		stroke: #f4e3a8;
		stroke-width: 1.2;
		stroke-opacity: 0.85;
		paint-order: stroke fill;
		filter: drop-shadow(0 0 4px rgba(246, 230, 170, 0.35));
	}

	/* Continuous "breathe" pulse on one hotspot (the 'about' fig) so a
	   first-time visitor notices at least one clickable thing on the
	   tree. Keep it gentle — this shouldn't be a flashing ad. The
	   .pulse-target sits inside the parent's translate/scale, so we
	   animate a small relative scale around (0,0). */
	@keyframes breathe {
		0%   { transform: scale(1); filter: drop-shadow(0 0 0 rgba(246, 230, 170, 0)); }
		50%  { transform: scale(1.1); filter: drop-shadow(0 0 6px rgba(246, 230, 170, 0.8)); }
		100% { transform: scale(1); filter: drop-shadow(0 0 0 rgba(246, 230, 170, 0)); }
	}
	.hotspot-pulse .pulse-target {
		transform-box: fill-box;
		transform-origin: center;
		animation: breathe 3.2s ease-in-out infinite;
	}
	.hotspot-pulse:hover .pulse-target {
		/* Pause the pulse while the user is interacting — hover takes over. */
		animation-play-state: paused;
	}

	/* One-shot "pssst" bob ~2s after load: every hotspot dips 3px down
	   then settles, so the tree looks momentarily alive and the eye
	   catches all five clickable spots. Runs once, then stops. The
	   continuous .hotspot-pulse keeps going after. */
	@keyframes pssst {
		0%   { transform: translate(0, 0); }
		20%  { transform: translate(0, -2px); }
		45%  { transform: translate(0, 3px); }
		70%  { transform: translate(0, -1px); }
		100% { transform: translate(0, 0); }
	}
	.hotspot.pssst {
		transform-box: fill-box;
		transform-origin: center;
		animation: pssst 1.6s ease-out 1;
	}

	@media (prefers-reduced-motion: reduce) {
		.hotspot-pulse .pulse-target { animation: none; }
		.hotspot.pssst { animation: none; }
	}

	/* Slow painterly cloud drift — three staggered offsets so the sky
	   feels alive without reading as synchronized motion. Respects
	   reduced-motion preference. */
	@keyframes driftA { from { transform: translateX(0); } to { transform: translateX(40px); } }
	@keyframes driftB { from { transform: translateX(0); } to { transform: translateX(-34px); } }
	@keyframes driftC { from { transform: translateX(0); } to { transform: translateX(26px); } }
	.drift-a { animation: driftA 90s ease-in-out infinite alternate; }
	.drift-b { animation: driftB 110s ease-in-out infinite alternate; }
	.drift-c { animation: driftC 130s ease-in-out infinite alternate; }
	@media (prefers-reduced-motion: reduce) {
		.drift-a, .drift-b, .drift-c { animation: none; }
	}
</style>

<script>
	const scene = document.getElementById('scene');
	if (scene) {
		let topZ = 10;

		// === Mobile scene adaptation ==========================================
		// The scene was composed for a 1440×900 viewBox with the tree in
		// x=0..620. On a narrow (≤ 640px) viewport we zoom into that left
		// slab so the tree + person + lower hills dominate instead of being
		// letterboxed or cropped oddly. We also enlarge every hotspot's
		// transparent hit-target circle so each tap target is ≥ 44px CSS.
		const svg = scene.querySelector<SVGSVGElement>('svg.landscape');
		const mobileQuery = window.matchMedia('(max-width: 640px)');
		const applyMobileScene = (isMobile: boolean) => {
			if (!svg) return;
			const desktopVB = svg.dataset.desktopViewbox || '0 0 1440 900';
			const mobileVB = svg.dataset.mobileViewbox || '-20 -30 720 930';
			svg.setAttribute('viewBox', isMobile ? mobileVB : desktopVB);
			// On mobile, `meet` shows the entire tree + hotspots (letterboxed
			// by the `.scene` sky-matching background). On desktop we keep
			// `xMinYMid slice` so the left-anchored tree stays in place.
			svg.setAttribute(
				'preserveAspectRatio',
				isMobile ? 'xMidYMid meet' : 'xMinYMid slice',
			);
			// Bump hit-target circles (the transparent <circle> inside each
			// hotspot group) so touch areas clear the 44×44 Apple guideline.
			// Mobile shows a 720×930 viewBox letterboxed in 375×812, so each
			// SVG unit ≈ 0.52 CSS px — a 26-unit circle = ~13.5 CSS px before
			// bumping. We push r to 48 on mobile, which renders ~25 CSS px
			// radius ≈ 50 CSS px diameter.
			scene
				.querySelectorAll<SVGCircleElement>('.hotspot > circle')
				.forEach((c) => {
					if (isMobile) {
						if (!c.dataset.origR) {
							c.dataset.origR = c.getAttribute('r') || '';
						}
						c.setAttribute('r', '48');
					} else if (c.dataset.origR) {
						c.setAttribute('r', c.dataset.origR);
					}
				});
		};
		applyMobileScene(mobileQuery.matches);
		if ('addEventListener' in mobileQuery) {
			mobileQuery.addEventListener('change', (e) => applyMobileScene(e.matches));
		}

		const bringToFront = (el: HTMLElement) => {
			topZ += 1;
			el.style.zIndex = String(topZ);
		};

		const openWindow = (id: string) => {
			const win = document.getElementById(`window-${id}`) as HTMLElement | null;
			if (!win) return;
			win.hidden = false;
			bringToFront(win);
		};

		const hotspots = scene.querySelectorAll<SVGElement>('.hotspot');
		hotspots.forEach((el) => {
			const id = (el as SVGElement & { dataset: DOMStringMap }).dataset.window;
			if (!id) return;
			el.addEventListener('click', () => openWindow(id));
			el.addEventListener('keydown', (e) => {
				const ke = e as KeyboardEvent;
				if (ke.key === 'Enter' || ke.key === ' ') {
					ke.preventDefault();
					openWindow(id);
				}
			});
		});

		// One-shot "pssst" bob ~1.8s after load so first-time visitors
		// catch the fact that things on the tree respond. The class is
		// removed after the animation completes so it doesn't loop.
		// Respect prefers-reduced-motion.
		const rm = window.matchMedia('(prefers-reduced-motion: reduce)');
		if (!rm.matches) {
			window.setTimeout(() => {
				hotspots.forEach((el, i) => {
					window.setTimeout(() => {
						el.classList.add('pssst');
						el.addEventListener(
							'animationend',
							() => el.classList.remove('pssst'),
							{ once: true }
						);
					}, i * 120);
				});
			}, 1800);
		}

		// Drag is disabled on narrow viewports — windows are centered via CSS
		// and overriding `left/top` with per-pixel values would fight that.
		const mobileMq = window.matchMedia('(max-width: 640px)');

		scene.querySelectorAll<HTMLElement>('.window').forEach((win) => {
			win.addEventListener('mousedown', () => bringToFront(win));

			win.querySelectorAll<HTMLButtonElement>('[data-close]').forEach((btn) => {
				btn.addEventListener('click', () => {
					win.hidden = true;
				});
			});

			const handle = win.querySelector<HTMLElement>('[data-drag-handle]');
			if (!handle) return;

			let dragging = false;
			let offsetX = 0;
			let offsetY = 0;

			handle.addEventListener('mousedown', (e) => {
				if (mobileMq.matches) return;
				if ((e.target as HTMLElement).closest('[data-close]')) return;
				dragging = true;
				const rect = win.getBoundingClientRect();
				offsetX = e.clientX - rect.left;
				offsetY = e.clientY - rect.top;
				e.preventDefault();
			});

			document.addEventListener('mousemove', (e) => {
				if (!dragging) return;
				win.style.left = `${e.clientX - offsetX}px`;
				win.style.top = `${e.clientY - offsetY}px`;
			});

			document.addEventListener('mouseup', () => {
				dragging = false;
			});
		});
	}
</script>
