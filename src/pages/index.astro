				<!-- Branch skeleton: dark slashes through the foliage -->
				<g class="branch-skeleton" stroke="url(#branchDark)" fill="none" stroke-linecap="round" opacity="0.85">
					<path d="M 310 180 Q 400 140, 500 110" stroke-width="11" />
					<path d="M 255 130 Q 180 100, 95 80" stroke-width="10" />
					<path d="M 330 260 Q 430 240, 540 230" stroke-width="8" />
