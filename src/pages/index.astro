				<path d="M 310 180 Q 400 140, 500 110" stroke-width="22" />
				<path d="M 310 180 Q 400 140, 500 110" stroke-width="14" stroke="#3a2818" />
				<path d="M 255 130 Q 180 100, 95 80" stroke-width="20" />
				<path d="M 255 130 Q 180 100, 95 80" stroke-width="12" stroke="#3a2818" />
				<path d="M 330 260 Q 430 240, 540 230" stroke-width="16" />
				<path d="M 330 260 Q 430 240, 540 230" stroke-width="9" stroke="#3a2818" />
				<path d="M 180 320 Q 100 310, 30 320" stroke-width="14" />
				<path d="M 340 380 Q 470 390, 580 400" stroke-width="14" />
				<path d="M 340 380 Q 470 390, 580 400" stroke-width="8" stroke="#3a2818" />
				<path d="M 500 110 Q 540 90, 580 70" stroke-width="6" />
				<path d="M 540 230 Q 590 220, 630 215" stroke-width="5" />
				<path d="M 95 80 Q 60 70, 20 65" stroke-width="6" />
			</g>

			<!-- ============================================================
			     CANOPY — dense overlapping palmate fig leaves
			     Built from an array of ~350 <use href="#figLeaf"> placements
			     in 3 depth layers, each tinted via a gradient fill.
			     The canopy SILHOUETTE itself becomes palmate because
			     the outermost leaves' lobed shapes form the edge.
			     ============================================================ -->
			<g class="canopy">
				{leaves.map((l) => (
					<use
						href={SHADE_SYMBOL[l.shade]}
						x={-60}
						y={-80}
						width={120}
						height={90}
						transform={`translate(${l.x.toFixed(2)} ${l.y.toFixed(2)}) rotate(${l.r.toFixed(1)}) scale(${l.s.toFixed(2)})`}
					/>
				))}
			</g>

			<!-- Static (decorative) figs scattered on the tree -->
			<g opacity="0.95">
				<use href="#ripeFig" x="200" y="150" width="20" height="24" />
				<use href="#ripeFig" x="400" y="170" width="18" height="22" />
				<use href="#ripeFig" x="140" y="240" width="19" height="23" />
				<use href="#ripeFig" x="510" y="340" width="18" height="22" />
				<use href="#ripeFig" x="360" y="300" width="17" height="21" />
				<use href="#ripeFig" x="260" y="60" width="16" height="20" />
				<use href="#ripeFig" x="450" y="250" width="17" height="21" />
				<use href="#ripeFig" x="100" y="180" width="18" height="22" />
			</g>

			<!-- =========================================================
			     PERSON — seated at base of tree, enlarged + tonal
			     Shifted right (off the trunk shadow) and scaled 1.4x.
			     Two tonal values: #2a2117 (dark) body + #5e6f4a (shirt)
			     ========================================================= -->
			<g transform="translate(365, 620) scale(1.4)">
				<!-- ground shadow -->
				<ellipse cx="28" cy="60" rx="82" ry="8" fill="#394a2b" opacity="0.5" />

				<!-- extended leg (back) - drawn first so other limbs overlap -->
				<g fill="#2a2117">
					<path d="M 34 10
					         Q 64 24, 86 42
					         Q 92 48, 86 52
					         Q 72 50, 52 38
					         Q 36 28, 30 18 Z" />
					<!-- shoe on extended leg -->
					<ellipse cx="92" cy="48" rx="11" ry="5" fill="#1a130c" />
				</g>

				<!-- bent knee (front leg) - pants dark -->
				<path d="M 4 28
				         Q 28 16, 48 -2
				         Q 54 -10, 46 -14
				         Q 36 -12, 24 0
				         Q 6 16, -4 26 Z"
					fill="#2a2117"
				/>
				<!-- shoe at bent knee tip -->
				<ellipse cx="48" cy="-10" rx="8" ry="4" fill="#1a130c" transform="rotate(-25 48 -10)" />

				<!-- torso (shirt: olive/sage so it separates from trunk) -->
				<path d="M -10 -8
				         Q -16 14, -8 34
				         Q 4 40, 18 36
				         Q 28 26, 28 8
				         Q 26 -10, 18 -20
				         Q 4 -22, -10 -8 Z"
					fill="#5e6f4a"
				/>
				<!-- shirt collar/shadow band -->
				<path d="M -8 -14
				         Q 2 -20, 18 -18
				         Q 22 -10, 16 -6
				         Q 4 -4, -8 -8 Z"
					fill="#485638"
				/>
				<!-- arm resting on bent knee (shirt color, with darker forearm) -->
				<path d="M 18 -4
				         Q 36 0, 46 8
				         Q 48 12, 44 14
				         Q 30 12, 16 4 Z"
					fill="#5e6f4a"
				/>
				<path d="M 38 10
				         Q 48 14, 54 20
				         Q 52 24, 46 22
				         Q 36 18, 32 14 Z"
					fill="#2a2117"
				/>

				<!-- neck -->
				<rect x="4" y="-24" width="10" height="10" rx="2" fill="#7a5a42" />

				<!-- head (skin-tone warm brown, distinct from shirt and trunk) -->
				<circle cx="10" cy="-34" r="13" fill="#8a6a4c" />
				<!-- ear hint -->
				<ellipse cx="-2" cy="-33" rx="2" ry="3" fill="#6a4e38" />
				<!-- hair: darker than skin, covers crown -->
				<path d="M -3 -44
				         Q 10 -52, 23 -42
				         Q 24 -36, 20 -34
				         Q 14 -38, 10 -38
				         Q 4 -38, -2 -34
				         Q -5 -38, -3 -44 Z"
					fill="#1a130c"
				/>

				<!-- subtle leg separation line between bent + extended legs -->
				<path d="M 4 28 Q 16 24, 30 18" stroke="#1a130c" stroke-width="1.5" fill="none" opacity="0.5" />
			</g>

			<!-- =========================================================
			     CLICKABLE HOTSPOTS — figs + leaves on the tree
			     ========================================================= -->
			<g class="leaves">
				<g class="hotspot" data-window="notes" transform="translate(520 110) rotate(15) scale(1.3)">
					<use href="#figLeaf" x="-60" y="-80" width="120" height="90" fill="url(#foliageLight)" />
					<circle cx="0" cy="-40" r="48" fill="transparent" />
				</g>
				<g class="hotspot" data-window="contact" transform="translate(70 120) rotate(-35) scale(1.25)">
					<use href="#figLeaf" x="-60" y="-80" width="120" height="90" fill="url(#foliageLight)" />
					<circle cx="0" cy="-40" r="46" fill="transparent" />
				</g>
			</g>

			<g class="figs">
				<g class="hotspot" data-window="about">
					<g transform="translate(300 200) scale(1.3)" filter="url(#figShadow)">
						<use href="#ripeFig" x="-22" y="-30" width="44" height="52" />
					</g>
					<circle cx="300" cy="200" r="26" fill="transparent" />
				</g>

				<g class="hotspot" data-window="projects">
					<g transform="translate(170 380) scale(1.35)" filter="url(#figShadow)">
						<use href="#ripeFig" x="-22" y="-30" width="44" height="52" />
						<use href="#ripeFig" x="8" y="-22" width="36" height="44" />
					</g>
					<circle cx="175" cy="380" r="32" fill="transparent" />
				</g>

				<g class="hotspot" data-window="now">
					<g transform="translate(460 340) scale(1.25)" filter="url(#figShadow)">
