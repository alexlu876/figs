				</g>
				{/* contact: left-side protruding leaf clearly outside the canopy mass */}
				<g class="hotspot hotspot-leaf" data-window="contact" tabindex="0" role="button" aria-label="Open contact" transform="translate(10 220) rotate(-105) scale(1.55)">
					<title>contact</title>
					<use href="#figLeaf" x="-60" y="-80" width="120" height="90" fill="url(#foliageLight)" />
					<circle cx="0" cy="-40" r="46" fill="transparent" />
