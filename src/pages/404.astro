---
import Base from '../layouts/Base.astro';
---

<Base title="not found · figtre.es" description="This branch doesn't seem to bear fruit.">
	<div class="page">
		<article class="window" aria-labelledby="nf-title">
			<header class="titlebar">
				<span class="rule" aria-hidden="true"></span>
				<span class="title" id="nf-title">
					<svg class="leaf" viewBox="-40 -40 80 80" width="16" height="16" aria-hidden="true">
						<path
							d="M 0 -34
							   C 8 -30, 14 -22, 16 -12
							   C 24 -14, 30 -8, 28 0
							   C 34 4, 32 14, 22 16
							   C 20 24, 10 28, 2 22
							   C -2 30, -14 28, -16 18
							   C -26 18, -30 8, -24 0
							   C -30 -6, -28 -18, -18 -18
							   C -14 -28, -6 -32, 0 -34 Z"
							fill="#577043"
							stroke="#2a3b20"
							stroke-width="1"
							stroke-linejoin="round"
						/>
						<path
							d="M 0 -30 L 0 22 M 0 -6 L -14 8 M 0 -6 L 14 8 M 0 8 L -10 20 M 0 8 L 10 20"
							stroke="#2a3b20"
							stroke-width="0.8"
							fill="none"
							stroke-linecap="round"
							opacity="0.55"
						/>
					</svg>
					<em>404 &mdash; not found</em>
				</span>
				<span class="rule" aria-hidden="true"></span>
			</header>

			<section class="body">
				<p class="code">error 404</p>
				<p class="lede">This branch didn't bear fruit.</p>
				<p>
					The page you were looking for has either been pruned, is still
					a seedling, or was never planted. Try another fig — there
					should be a few hanging on the tree.
				</p>
			</section>

			<footer class="foot">
				<a class="back" href="/">&larr; back to the tree</a>
				<a class="back" href="/notes">notes</a>
			</footer>
		</article>
	</div>
</Base>

<style>
	.page {
		min-height: 100vh;
		padding: 4rem 1.5rem 5rem;
		display: flex;
		justify-content: center;
		align-items: flex-start;
		background:
			radial-gradient(1100px 700px at 50% -10%, #afc4d2 0%, #c4d1cf 45%, #d6dcd6 80%, #dfe2d5 100%),
			#dfe2d5;
		background-attachment: fixed;
		position: relative;
	}
	.page::before {
		content: '';
		position: absolute;
		inset: 0;
		pointer-events: none;
		opacity: 0.25;
		background-image:
			radial-gradient(rgba(30, 30, 30, 0.05) 1px, transparent 1px),
			radial-gradient(rgba(255, 255, 255, 0.06) 1px, transparent 1px);
		background-size: 3px 3px, 4px 4px;
		background-position: 0 0, 1px 2px;
		mix-blend-mode: multiply;
	}

	.window {
		position: relative;
		width: min(92vw, 560px);
		background: #ede8dc;
		border: 1px solid #1f1f1f;
		box-shadow: 4px 4px 0 rgba(0, 0, 0, 0.2);
		color: #1f1f1f;
	}

	.titlebar {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		padding: 0.5rem 0.75rem;
		border-bottom: 1px solid #1f1f1f;
	}
	.rule {
		flex: 1;
		height: 5px;
		border-top: 1px solid #1f1f1f;
		border-bottom: 1px solid #1f1f1f;
	}
	.title {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		font-style: italic;
		font-size: 1.05rem;
		white-space: nowrap;
	}
	.title .leaf { display: block; }

	.body {
		padding: 1.75rem 2rem 1.5rem;
		line-height: 1.65;
	}
	.code {
		margin: 0 0 0.75rem;
		font-family: ui-monospace, 'SFMono-Regular', Menlo, Consolas, monospace;
		font-size: 0.85rem;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: #5a2d42;
		opacity: 0.85;
	}
	.lede {
		margin: 0 0 0.9rem;
		font-style: italic;
		font-size: 1.1rem;
	}
	.body p { margin: 0.5rem 0; }

	.foot {
		border-top: 1px solid #1f1f1f;
		padding: 0.75rem 1rem;
		display: flex;
		justify-content: center;
		gap: 0.75rem;
	}
	.back {
		background: #ede8dc;
		border: 1px solid #1f1f1f;
		padding: 0.35rem 1.25rem;
		font-family: inherit;
		font-style: italic;
		font-size: 0.95rem;
		color: #1f1f1f;
		text-decoration: none;
	}
	.back:hover { background: #dcd5c4; }
	.back:focus-visible {
		outline: 2px dashed #3a5070;
		outline-offset: 3px;
	}

	@media (max-width: 640px) {
		.page { padding: 2rem 1rem 3rem; }
		.body { padding: 1.25rem 1.25rem 1rem; }
	}
</style>
