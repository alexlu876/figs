---
interface Props {
	title?: string;
	description?: string;
}

const { title = 'figtre.es', description = 'Something is growing here.' } = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root { color-scheme: dark; }
	html, body {
		margin: 0;
		min-height: 100%;
		background: #0a0a0a;
		color: #f5f5f0;
		font-family: ui-serif, Georgia, serif;
	}
	a { color: inherit; }
</style>
