---
interface Props {
	title?: string;
	description?: string;
}

const { title = 'figtre.es', description = 'Something is growing here.' } = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" href="data:," />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	html, body {
		margin: 0;
		min-height: 100%;
		font-family: ui-serif, Georgia, serif;
		color: #1f1f1f;
		background: #ede8dc;
	}
	a { color: inherit; }
</style>
